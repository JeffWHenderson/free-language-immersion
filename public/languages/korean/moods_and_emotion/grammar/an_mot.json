{
  "id": "an_mot",
  "name": "안 vs 못 — Negation",
  "language": "korean",
  "cards": [
    {
      "id": "an_intro",
      "levels": [
        {
          "front": "안 (general negation — won't)",
          "back": "안",
          "romanized": "an",
          "grammarNote": "안 goes directly before the verb/adjective: 안 가요 (I don't go). For 하다 verbs, 안 splits them: 공부 안 해요 (I don't study) — NOT 안 공부해요."
        }
      ]
    },
    {
      "id": "mot_intro",
      "levels": [
        {
          "front": "못 (inability — can't)",
          "back": "못",
          "romanized": "mot",
          "grammarNote": "못 expresses inability — you want to but can't. For 하다 verbs: 공부 못 해요 (I can't study). 못 + verb before the verb: 못 가요 (I can't go)."
        }
      ]
    },
    {
      "id": "dont_go",
      "levels": [
        {
          "front": "I don't go. (choice)",
          "back": "안 가요.",
          "romanized": "An gayo.",
          "grammarNote": "안 = won't / doesn't — no external barrier, just choice or general state."
        }
      ]
    },
    {
      "id": "cant_go",
      "levels": [
        {
          "front": "I can't go. (inability)",
          "back": "못 가요.",
          "romanized": "Mot gayo.",
          "grammarNote": "못 = can't — something prevents you (too busy, physically unable, etc.)."
        }
      ]
    },
