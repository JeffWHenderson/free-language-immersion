{
  "id": "eul_reul",
  "name": "을/를 — Object Marker",
  "language": "korean",
  "cards": [
    {
      "id": "coffee_obj",
      "front": "coffee (object marker)",
      "back": "커피를",
      "romanized": "keopireul",
      "grammarNote": "커피 ends in vowel 이, so 를 is used. 커피를 마셔요 = I drink coffee."
    },
    {
      "id": "rice_obj",
      "front": "rice (object marker)",
      "back": "밥을",
      "romanized": "babeul",
      "grammarNote": "밥 ends in consonant ㅂ, so 을 is used. 밥을 먹어요 = I eat rice."
    },
    {
      "id": "water_obj",
      "front": "water (object marker)",
      "back": "물을",
      "romanized": "mureul",
