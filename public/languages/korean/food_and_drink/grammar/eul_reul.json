    {
      "id": "i_drink_coffee",
      "front": "I drink coffee.",
      "back": "저는 커피를 마셔요.",
      "romanized": "Jeoneun keopireul masyeoyo.",
      "grammarNote": "Subject (저는) + Object (커피를) + Verb (마셔요). Korean word order: SOV."
    },
    {
      "id": "she_eats_rice",
      "front": "She eats rice.",
      "back": "그녀는 밥을 먹어요.",
      "romanized": "Geunyeoneun babeul meogeoyo.",
      "grammarNote": "밥을 = rice (object). The object marker tells us what is being eaten."
    },
    {
      "id": "i_study_korean",
      "front": "I study Korean.",
      "back": "저는 한국어를 공부해요.",
      "romanized": "Jeoneun hangugeoreul gongbuhaeyo.",
      "grammarNote": "한국어를 = Korean (object). 공부하다 = to study."
    },
    {
      "id": "i_like_apples",
      "front": "I like apples.",
      "back": "사과를 좋아해요.",
      "romanized": "Sagwareul joahaeyo.",
      "grammarNote": "좋아하다 (to like) takes the object marker on what is liked: 사과를 좋아해요."
