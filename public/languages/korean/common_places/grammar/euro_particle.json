{
  "id": "euro_particle",
  "name": "-(으)로 — Direction & Means",
  "language": "korean",
  "cards": [
    {
      "id": "ep_rule",
      "front": "What is the rule for choosing 로 vs 으로?",
      "back": "로 after vowels and ㄹ; 으로 after other consonants",
      "romanized": "ro / euro",
      "grammarNote": "The particle -(으)로 shows direction or means. Use 로 when the noun ends in a vowel or ㄹ (e.g., 지하철로, 서울로). Use 으로 when the noun ends in any other consonant (e.g., 오른쪽으로, 북쪽으로)."
    },
    {
      "id": "ep_right",
      "front": "Turn to the right",
      "back": "오른쪽으로 도세요",
      "romanized": "oreunjjogeuro doseyo"
    },
    {
      "id": "ep_left",
      "front": "Turn to the left",
      "back": "왼쪽으로 도세요",
      "romanized": "oenjjogeuro doseyo"
    },
    {
      "id": "ep_this_way",
      "front": "Come this way",
      "back": "이쪽으로 오세요",
      "romanized": "ijjogeuro oseyo"
    },
    {
      "id": "ep_bus_to_seoul",
      "front": "A bus going to Seoul",
      "back": "서울로 가는 버스",
      "romanized": "Seoul-lo ganeun beoseu",
      "grammarNote": "서울 ends in ㄹ, so it takes 로 (not 으로): 서울로. This is the direction use of -(으)로."
    },
    {
      "id": "ep_subway",
      "front": "I go by subway",
      "back": "지하철로 가요",
      "romanized": "jihacheolro gayo"
    },
    {
      "id": "ep_bus",
      "front": "I came by bus",
      "back": "버스로 왔어요",
      "romanized": "beoseuro wasseoyo"
    },
    {
      "id": "ep_taxi",
      "front": "I will go by taxi",
      "back": "택시로 갈 거예요",
      "romanized": "taeksiro gal geoyeyo"
    },
    {
      "id": "ep_on_foot",
      "front": "I go on foot (to work)",
      "back": "걸어서 출근해요",
      "romanized": "georeoeseo chulgeunhaeyo",
      "grammarNote": "'On foot' uses 걸어서 (from 걷다, to walk + 아서/어서), NOT 걸어로. This is an exception — walking is expressed as a sequential action, not with the direction/means particle."
    },
    {
      "id": "ep_subway_to_station",
      "front": "How do I get to the station? (by subway)",
      "back": "지하철로 역에 가세요",
      "romanized": "jihacheolro yeoge gaseyo"
    },
    {
      "id": "ep_which_way",
      "front": "Which way is the hotel?",
      "back": "호텔은 어느 쪽으로 가요?",
      "romanized": "hoteleun eoneu jjogeuro gayo"
    },
    {
      "id": "ep_exit",
      "front": "Go through the main exit",
      "back": "정문으로 나가세요",
      "romanized": "jeongmuneuro nagaseyo"
    }
  ]
}
