{
  "id": "past_tense",
  "name": "Past Tense — 았어요/었어요",
  "language": "korean",
  "cards": [
    {
      "id": "cpt_went",
      "front": "I went (가다 — past)",
      "back": "갔어요",
      "romanized": "gasseoyo",
      "grammarNote": "가다 → 갔어요: the stem 가- ends in ㅏ vowel, so it takes 았어요, which contracts with the stem: 가+았 = 갔. This is one of the most frequent past-tense forms."
    },
    {
      "id": "cpt_came",
      "front": "I came (오다 — past)",
      "back": "왔어요",
      "romanized": "wasseoyo"
    },
