{
  "id": "ibnida_iseyo",
  "name": "입니다 vs 이에요 — To Be",
  "language": "korean",
  "cards": [
    {
      "id": "i_am_student_polite",
      "front": "I am a student. (polite)",
      "back": "저는 학생이에요.",
      "romanized": "Jeoneun haksaengieyo.",
      "grammarNote": "학생 ends in consonant (ng), so 이에요 is used. This is the informal polite register, suitable for most daily situations."
    },
    {
      "id": "i_am_doctor_polite",
      "front": "I am a doctor. (polite)",
      "back": "저는 의사예요.",
      "romanized": "Jeoneun uisayeyo.",
      "grammarNote": "의사 ends in vowel (a), so 예요 is used (not 이에요)."
    },
    {
      "id": "i_am_student_formal",
      "front": "I am a student. (formal)",
      "back": "저는 학생입니다.",
      "romanized": "Jeoneun haksaengimnida.",
      "grammarNote": "입니다 is the formal polite form. It does not change based on whether the noun ends in a vowel or consonant — it is always 입니다."
    },
    {
      "id": "this_is_coffee",
      "front": "This is coffee.",
      "back": "이것은 커피예요.",
      "romanized": "Igeoseun keopiyeyo.",
      "grammarNote": "커피 ends in vowel 이, so 예요 is used."
    },
    {
      "id": "this_is_book",
      "front": "This is a book.",
      "back": "이것은 책이에요.",
      "romanized": "Igeoseun chaegieyo.",
      "grammarNote": "책 ends in consonant ㄱ, so 이에요 is used."
    },
    {
      "id": "she_is_teacher",
      "front": "She is a teacher.",
      "back": "그녀는 선생님이에요.",
      "romanized": "Geunyeoneun seonsaengnimieyo.",
      "grammarNote": "선생님 ends in consonant (m), so 이에요 is used."
    },
    {
      "id": "he_is_korean",
      "front": "He is Korean.",
      "back": "그는 한국 사람이에요.",
      "romanized": "Geuneun hanguk saramieyo.",
      "grammarNote": "사람 ends in consonant (m), so 이에요. 한국 사람 = Korean person."
    },
    {
      "id": "not_a_student",
      "front": "I am not a student.",
      "back": "저는 학생이 아니에요.",
      "romanized": "Jeoneun haksaengi anieyo.",
      "grammarNote": "Negative form: noun + 이/가 + 아니에요. 학생 ends in consonant, so 이 아니에요."
    },
    {
      "id": "not_a_doctor",
      "front": "I am not a doctor.",
      "back": "저는 의사가 아니에요.",
      "romanized": "Jeoneun uisaga anieyo.",
      "grammarNote": "의사 ends in vowel, so 가 아니에요 is used."
    },
    {
      "id": "are_you_student",
      "front": "Are you a student?",
      "back": "학생이에요?",
      "romanized": "Haksaengieyo?",
      "grammarNote": "Questions use the same form with rising intonation. No special question word needed."
    },
    {
      "id": "what_is_this",
      "front": "What is this?",
      "back": "이게 뭐예요?",
      "romanized": "Ige mwoyeyo?",
      "grammarNote": "뭐 (what) ends in vowel, so 예요 is used. 이게 is the contracted form of 이것이 (this + subject marker)."
    },
    {
      "id": "my_name_is",
      "front": "My name is Jeff.",
      "back": "제 이름은 Jeff예요.",
      "romanized": "Je ireumeun Jeff yeyo.",
      "grammarNote": "Jeff ends in vowel sound, so 예요. If your name ends in a consonant sound, use 이에요 instead."
    },
    {
      "id": "casual_form",
      "front": "It's a dog. (casual)",
      "back": "강아지야.",
      "romanized": "Gangajiya.",
      "grammarNote": "Very casual form: 이야 after consonant, 야 after vowel. 강아지 ends in vowel, so 야. Only use with close friends of similar age."
    },
    {
      "id": "formal_question",
      "front": "Are you a student? (formal)",
      "back": "학생입니까?",
      "romanized": "Haksaengiimnikka?",
      "grammarNote": "Formal question form: 입니까. Used in professional, military, or very formal contexts. Much less common in daily speech."
    },
    {
      "id": "office_worker",
      "front": "I am an office worker.",
      "back": "저는 직장인이에요.",
      "romanized": "Jeoneun jikjangini-eyo.",
      "grammarNote": "직장인 ends in consonant (n), so 이에요."
    },
    {
      "id": "where_is_from",
      "front": "She is from America.",
      "back": "그녀는 미국 사람이에요.",
      "romanized": "Geunyeoneun miguk saramieyo.",
      "grammarNote": "미국 사람 (American person), 사람 ends in consonant (m) → 이에요."
    }
  ]
