{
  "id": "ga_apayo",
  "name": "이/가 아파요 — Expressing Pain",
  "language": "korean",
  "cards": [
    {
      "id": "apayo",
      "levels": [
        {
          "front": "hurts",
          "back": "아파요",
          "romanized": "apayo",
          "grammarNote": "아프다 = to hurt / to be sick. Pattern: [body part] + 이/가 + 아파요. The subject marker 이/가 marks the body part that hurts."
        }
      ]
    },
    {
      "id": "head_hurts",
      "levels": [
        {
          "front": "My head hurts.",
          "back": "머리가 아파요.",
          "romanized": "Meoriga apayo.",
          "grammarNote": "머리 (head) ends in 이 (vowel) → 가 is used. 머리가 아파요."
        }
      ]
    },
    {
      "id": "stomach_hurts",
      "levels": [
        {
          "front": "My stomach hurts.",
          "back": "배가 아파요.",
          "romanized": "Baega apayo.",
          "grammarNote": "배 (stomach/belly) ends in vowel → 가. 배가 아파요."
        }
      ]
    },
    {
      "id": "throat_hurts",
      "levels": [
        {
          "front": "My throat hurts.",
          "back": "목이 아파요.",
          "romanized": "Mogi apayo.",
          "grammarNote": "목 (throat/neck) ends in consonant ㄱ → 이. 목이 아파요."
        }
      ]
    },
    {
      "id": "back_hurts",
      "levels": [
        {
          "front": "My back hurts.",
          "back": "등이 아파요.",
          "romanized": "Deungi apayo.",
          "grammarNote": "등 (back) ends in consonant ㅇ → 이. 등이 아파요."
        }
      ]
    },
    {
      "id": "foot_hurts",
      "levels": [
        {
          "front": "My foot hurts.",
