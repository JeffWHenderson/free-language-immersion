        }
      ]
    },
    {
      "id": "where_hurts",
      "levels": [
        {
          "front": "Where does it hurt?",
          "back": "어디가 아파요?",
          "romanized": "Eodiga apayo?",
          "grammarNote": "어디 (where) + 가 (subject marker) + 아파요? This is the standard way to ask where someone is in pain."
        }
      ]
    },
    {
      "id": "body_hurts",
      "levels": [
        {
          "front": "I feel sick. (my body hurts)",
          "back": "몸이 아파요.",
          "romanized": "Momi apayo.",
          "grammarNote": "몸 (body) + 이 + 아파요. This can mean either 'I feel sick' or 'my body aches all over.'"
        }
      ]
    },
    {
      "id": "everywhere_hurts",
      "levels": [
        {
          "front": "I hurt everywhere.",
          "back": "온몸이 아파요.",
          "romanized": "Onmomi apayo.",
          "grammarNote": "온몸 = whole body. 온몸이 아파요 = my whole body hurts."
        }
      ]
    },
    {
      "id": "very_painful",
      "levels": [
        {
          "front": "It hurts a lot.",
          "back": "너무 아파요.",
          "romanized": "Neomu apayo.",
          "grammarNote": "너무 = too much / very (in spoken Korean, 너무 often just means 'very'). 너무 아파요 = it hurts a lot."
        }
      ]
    }
  ]
