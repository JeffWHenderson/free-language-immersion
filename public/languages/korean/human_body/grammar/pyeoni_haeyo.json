{
  "id": "pyeoni_haeyo",
  "name": "-(으)면 좋겠어요 / -는 게 좋아요 — I'd Better / It's Better To",
  "language": "korean",
  "cards": [
    {
      "id": "should_rest",
      "front": "You should rest.",
      "back": "쉬는 게 좋아요.",
      "romanized": "Swineun ge joayo.",
      "grammarNote": "V-는 게 좋아요 = it's better to / you should [verb]. 쉬다 (to rest) → 쉬는 게 좋아요. Use this pattern to give gentle advice."
    },
    {
      "id": "take_medicine",
      "front": "I have to take medicine.",
      "back": "약을 먹어야 해요.",
      "romanized": "Yageul meogeoaya haeyo.",
      "grammarNote": "V-아야/어야 해요 = must / have to. 먹다 (to eat/take) has stem 먹 (ends in consonant) + 어야 해요 → 먹어야 해요.",
      "literal": "Medicine [obj] must eat."
    },
    {
      "id": "see_doctor",
      "front": "You'd better see a doctor.",
      "back": "병원에 가는 게 좋아요.",
      "romanized": "Byeongwone ganeun ge joayo.",
      "grammarNote": "가다 (to go) → 가는 게 좋아요. 병원 = hospital/clinic. This is softer than a direct command.",
      "literal": "Hospital-to going is better."
    },
    {
      "id": "should_sleep_early",
      "front": "You should sleep early.",
      "back": "일찍 자는 게 좋아요.",
      "romanized": "Iljjik janeun ge joayo.",
      "grammarNote": "자다 (to sleep) → 자는 게 좋아요. 일찍 = early.",
      "literal": "Early sleeping is better."
    },
    {
      "id": "must_drink_water",
      "front": "You must drink water.",
      "back": "물을 마셔야 해요.",
      "romanized": "Mureul masyeoaya haeyo.",
      "grammarNote": "마시다 (to drink) → stem 마시 + 어야 해요 → 마셔야 해요 (contracted). 물 = water.",
      "literal": "Water [obj] must drink."
    },
    {
      "id": "should_exercise",
      "front": "You should exercise regularly.",
      "back": "규칙적으로 운동하는 게 좋아요.",
      "romanized": "Gyuchikjeogeuro undonghaneun ge joayo.",
      "grammarNote": "운동하다 (to exercise) → 운동하는 게 좋아요. 규칙적으로 = regularly.",
      "literal": "Regularly exercising is better."
    },
    {
      "id": "must_go_hospital",
      "front": "I have to go to the hospital.",
      "back": "병원에 가야 해요.",
      "romanized": "Byeongwone gaya haeyo.",
      "grammarNote": "가다 (to go) → 가야 해요. The stem 가 ends in vowel ㅏ → use 아야 해요 → 가 + 아야 해요 = 가야 해요.",
      "literal": "Hospital-to must go."
    },
    {
      "id": "should_not_overwork",
      "front": "You shouldn't overwork.",
      "back": "무리하지 않는 게 좋아요.",
      "romanized": "Murihaji anneun ge joayo.",
      "grammarNote": "To negate V-는 게 좋아요, use V-지 않는 게 좋아요. 무리하다 = to overwork / push too hard.",
      "literal": "Not-overworking is better."
    },
    {
      "id": "must_rest_today",
      "front": "You must rest today.",
      "back": "오늘은 쉬어야 해요.",
      "romanized": "Oneureun swieoya haeyo.",
      "grammarNote": "쉬다 (to rest) → stem 쉬 + 어야 해요 → 쉬어야 해요. 오늘은 = today (topic).",
      "literal": "Today [topic] must rest."
    },
    {
      "id": "should_eat_well",
      "front": "You should eat well.",
      "back": "잘 먹는 게 좋아요.",
      "romanized": "Jal meongneun ge joayo.",
      "grammarNote": "먹다 (to eat) → 먹는 게 좋아요. 잘 = well.",
      "literal": "Well eating is better."
    },
    {
      "id": "had_better_check",
      "front": "You'd better get a check-up.",
      "back": "검사를 받는 게 좋아요.",
      "romanized": "Geomsareul batneun ge joayo.",
      "grammarNote": "받다 (to receive) → 받는 게 좋아요. 검사를 받다 = to receive/get an examination.",
      "literal": "Examination [obj] receiving is better."
    },
    {
      "id": "must_take_prescription",
      "front": "You have to take the prescribed medicine.",
      "back": "처방받은 약을 먹어야 해요.",
      "romanized": "Cheobangbadeun yageul meogeoaya haeyo.",
      "grammarNote": "처방받다 = to be prescribed. 처방받은 약 = prescribed medicine. 먹어야 해요 = must take.",
      "literal": "Prescribed medicine [obj] must eat."
    }
  ]
}
