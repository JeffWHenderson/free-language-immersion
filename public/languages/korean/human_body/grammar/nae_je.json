      "front": "I (informal)",
      "back": "나",
      "romanized": "na",
      "grammarNote": "나 = I in informal/casual speech. Used with close friends, younger people, or in casual writing. 내 (my) comes from 나 + 의."
    },
    {
      "id": "i_formal",
      "front": "I (formal)",
      "back": "저",
      "romanized": "jeo",
      "grammarNote": "저 = I in formal/polite speech. Used with strangers, elders, superiors, or anyone you should show respect to. 제 (my) comes from 저 + 의."
    },
