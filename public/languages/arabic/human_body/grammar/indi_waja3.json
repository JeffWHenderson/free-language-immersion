{
  "id": "indi_waja3",
  "name": "عندي وجع — Expressing Pain",
  "language": "arabic",
  "cards": [
    {
      "id": "waja3",
      "front": "pain",
      "back": "وجع",
      "romanized": "waja'",
      "grammarNote": "وجع (waja') = pain, ache — very common in colloquial Arabic. Pattern to express pain: عندي وجع + body part (I have a [body part] ache)."
    },
    {
      "id": "headache",
      "front": "I have a headache.",
      "back": "عندي وجع رأس.",
      "romanized": "indi waja' ra's.",
      "grammarNote": "عندي = I have (lit. 'at me'). رأس = head. عندي وجع رأس = I have head pain. This colloquial structure is used throughout the Arab world."
    },
    {
      "id": "stomachache",
      "front": "I have a stomach ache.",
      "back": "عندي وجع بطن.",
      "romanized": "indi waja' batn."
    },
    {
      "id": "toothache",
      "front": "I have a toothache.",
      "back": "عندي وجع أسنان.",
      "romanized": "indi waja' asnan."
    },
    {
      "id": "backache",
      "front": "I have a backache.",
      "back": "عندي وجع ظهر.",
      "romanized": "indi waja' dahr."
    },
    {
      "id": "sore_throat",
      "front": "I have a sore throat.",
      "back": "عندي وجع حلق.",
      "romanized": "indi waja' halq."
    },
    {
      "id": "head_hurts_msa",
      "front": "My head hurts. (more formal)",
      "back": "رأسي يؤلمني.",
      "romanized": "ra'si yu'limuni.",
      "grammarNote": "يؤلمني (yu'limuni) = hurts me, from the verb أَلَمَ (to hurt). This is the MSA structure: [body part] + يؤلمني. More formal than عندي وجع."
    },
    {
      "id": "stomach_hurts_msa",
      "front": "My stomach hurts.",
      "back": "بطني يؤلمني.",
      "romanized": "batni yu'limuni."
    },
    {
      "id": "im_sick",
      "front": "I am sick",
      "back": "أنا مريض.",
      "romanized": "ana maridh.",
      "grammarNote": "مريض (maridh) = sick (masculine). Feminine: مريضة (maridha). Colloquial alternative: أنا تعبان (ana ta'ban = I'm worn out / not feeling well)."
    },
    {
      "id": "not_well",
      "front": "I don't feel well. (colloquial)",
      "back": "مش بخير.",
      "romanized": "mish bi-khayr.",
      "grammarNote": "مش = not (colloquial). بخير = well/fine. مش بخير = not fine/not well. Very natural in Levantine and Egyptian Arabic."
    },
    {
      "id": "where_hurts",
      "front": "Where does it hurt?",
      "back": "وين يوجعك؟",
      "romanized": "ween yuwji'ak?",
      "grammarNote": "وين (ween) = where (Levantine). يوجعك = hurts you. MSA: أين يؤلمك؟ (ayna yu'limuka?)."
    },
    {
      "id": "hurts_here",
      "front": "It hurts here.",
      "back": "يوجعني هون.",
      "romanized": "yuwji'ni hoon.",
      "grammarNote": "هون = here (Levantine). MSA: يؤلمني هنا (yu'limuni huna)."
    },
    {
      "id": "fever",
      "front": "I have a fever.",
      "back": "عندي حرارة.",
      "romanized": "indi harara.",
      "grammarNote": "حرارة (harara) = heat/fever. عندي حرارة = I have a fever (lit. 'I have heat'). Very common expression throughout Arabic-speaking countries."
    },
    {
      "id": "cold",
      "front": "I have a cold.",
      "back": "عندي زكام.",
      "romanized": "indi zukam."
    },
    {
      "id": "need_doctor",
      "front": "I need a doctor.",
      "back": "بدي دكتور.",
      "romanized": "biddi duktur.",
      "grammarNote": "بدي (biddi) = I want/need (Levantine). MSA: أحتاج طبيباً (ahtaj tabiban). دكتور is the common colloquial word for doctor."
    },
    {
      "id": "leg_hurts",
      "front": "My leg hurts.",
      "back": "ساقي بتوجعني.",
      "romanized": "saqi bituwji'ni."
    },
    {
      "id": "very_painful",
      "front": "It hurts a lot.",
      "back": "بوجعني كتير.",
      "romanized": "buwji'ni ktir.",
      "grammarNote": "كتير = a lot (Levantine). بوجعني كتير = it hurts me a lot."
    }
  ]
}
