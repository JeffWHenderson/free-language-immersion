{
  "id": "adjective_agreement",
  "name": "المطابقة — Adjective Agreement",
  "language": "arabic",
  "cards": [
    {
      "id": "agreement_rule",
      "front": "Adjectives agree in gender and definiteness.",
      "back": "كبير / كبيرة",
      "romanized": "kabir / kabira",
      "grammarNote": "Arabic adjectives match the noun in gender (masc/fem), number (sing/plural), and definiteness (definite/indefinite). Most fem. adjectives add ة (a)."
    },
    {
      "id": "yad_kabira",
      "front": "a big hand",
      "back": "يد كبيرة",
      "romanized": "yad kabira",
      "grammarNote": "يد (hand) is feminine, so the adjective is كبيرة (kabira), not كبير (kabir)."
    },
    {
      "id": "ras_kabir",
      "front": "a big head",
      "back": "رأس كبير",
      "romanized": "ra's kabir",
      "grammarNote": "رأس (head) is masculine, so the adjective is كبير (kabir)."
    },
    {
      "id": "al_yad_al_kabira",
      "front": "the big hand",
      "back": "اليد الكبيرة",
      "romanized": "al-yad al-kabira",
      "grammarNote": "When definite, both noun and adjective take الـ: اليد الكبيرة (the big hand)."
    },
    {
      "id": "alam_shadid",
      "front": "severe pain",
      "back": "ألم شديد",
      "romanized": "alam shadid",
      "grammarNote": "ألم (pain) is masculine, so شديد (severe/intense) matches: شديد not شديدة."
    },
    {
      "id": "rijl_mukhfafa",
      "front": "a swollen leg",
      "back": "رجل متورمة",
      "romanized": "rijl mutawarrama",
      "grammarNote": "رجل (leg) is feminine in Arabic, so the adjective متورمة (swollen) takes the fem. ending ة."
    },
    {
      "id": "daghta_aliya",
      "front": "high blood pressure",
      "back": "ضغط دم عالٍ",
      "romanized": "daght damm 'alin"
    },
    {
      "id": "waja_shadid",
      "front": "severe pain",
      "back": "وجع شديد",
      "romanized": "waja' shadid"
    },
    {
      "id": "kasur_basit",
      "front": "a simple fracture",
      "back": "كسر بسيط",
      "romanized": "kasr basit"
    },
    {
      "id": "good_health",
      "front": "good health",
      "back": "صحة جيدة",
      "romanized": "sihha jayyida",
      "grammarNote": "صحة (health) is feminine — جيدة (good, fem.) matches."
    },
    {
      "id": "i_am_tired",
      "front": "I am tired. (male speaker)",
      "back": "أنا متعب.",
      "romanized": "ana muta'ab.",
      "grammarNote": "Predicate adjectives agree with the subject. Male speaker: متعب (muta'ab). Female speaker: أنا متعبة (muta'aba)."
    },
    {
      "id": "she_is_tired",
      "front": "She is tired.",
      "back": "هي متعبة.",
      "romanized": "hiya muta'aba."
    }
  ]
}
