{
  "id": "la_negation",
  "name": "لا & ما — Negation",
  "language": "arabic",
  "cards": [
    {
      "id": "la",
      "front": "no / not",
      "back": "لا",
      "romanized": "la",
      "grammarNote": "لا negates verbs in the present tense: لا أشعر بألم (I don't feel pain). Also used as a standalone 'no.'"
    },
    {
      "id": "laysa",
      "front": "is not / am not",
      "back": "ليس",
      "romanized": "laysa",
      "grammarNote": "ليس (laysa) negates equational sentences. ليس + noun/adj = is not. لست (lastu) = I am not."
    },
    {
      "id": "la_alam",
      "front": "no pain",
      "back": "لا ألم.",
      "romanized": "la alam.",
      "grammarNote": "لا + indefinite noun = there is no X. لا ألم = no pain / there is no pain."
    },
    {
      "id": "la_ashur_bialm",
      "front": "I don't feel pain.",
      "back": "لا أشعر بألم.",
      "romanized": "la ash'ur bi-alam."
    },
    {
      "id": "la_urid_dawa",
      "front": "I don't want medicine.",
      "back": "لا أريد دواء.",
      "romanized": "la urid dawa'."
    },
    {
      "id": "laysat_huna",
      "front": "It's not here.",
      "back": "ليست هنا.",
      "romanized": "laysat huna.",
      "grammarNote": "ليست is the feminine form of ليس. Used when the subject is feminine."
    },
    {
      "id": "la_mushkila",
      "front": "No problem.",
      "back": "لا مشكلة.",
      "romanized": "la mushkila."
    },
    {
      "id": "not_broken",
      "front": "It's not broken.",
      "back": "ليس مكسوراً.",
      "romanized": "laysa maksūran."
    },
    {
      "id": "not_serious",
      "front": "It's not serious.",
      "back": "ليس خطيراً.",
      "romanized": "laysa khatiran."
    },
    {
      "id": "not_fever",
      "front": "I don't have a fever.",
      "back": "لا توجد لدي حمى.",
      "romanized": "la tūjad ladayya humma.",
      "grammarNote": "لا يوجد / لا توجد = there is no (masc./fem.). لديّ = at me / I have (prepositional possessive)."
    },
    {
      "id": "no_allergy",
      "front": "I have no allergies.",
      "back": "ليس لدي حساسية.",
      "romanized": "laysa ladayya hasasiyya."
    }
  ]
}
