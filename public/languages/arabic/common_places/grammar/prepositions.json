{
  "id": "prepositions",
  "name": "حروف الجر — Prepositions",
  "language": "arabic",
  "cards": [
    {
      "id": "fi",
      "levels": [
        {
          "front": "in",
          "back": "في",
          "romanized": "fi",
          "grammarNote": "في (fi) = in, at, inside. Used for being inside a place: في البيت (in the house). Also used for time: في الصباح (in the morning). One of the most frequently used Arabic words."
        }
      ]
    },
    {
      "id": "ala",
      "levels": [
        {
          "front": "on",
          "back": "على",
          "romanized": "'ala",
          "grammarNote": "على ('ala) = on, on top of. الكتاب على الطاولة (the book is on the table). Contrast with في (inside): في الحقيبة (in the bag) vs على الحقيبة (on the bag)."
        }
      ]
    },
    {
      "id": "min",
      "levels": [
        {
          "front": "from",
          "back": "من",
          "romanized": "min",
          "grammarNote": "من (min) = from, of. أنا من الأردن (I am from Jordan). Also used in phrases: من فضلك (please, lit. 'from your grace')."
        }
      ]
    },
    {
      "id": "ila",
      "levels": [
        {
          "front": "to",
          "back": "إلى",
          "romanized": "ila",
          "grammarNote": "إلى (ila) = to, toward. نذهب إلى المطعم (we go to the restaurant). Used for direction and destination."
        }
      ]
    },
    {
      "id": "maa",
      "levels": [
        {
          "front": "with (together with)",
          "back": "مع",
          "romanized": "ma'"
        }
      ]
    },
    {
      "id": "an",
      "levels": [
        {
          "front": "about",
          "back": "عن",
          "romanized": "'an",
          "grammarNote": "عن ('an) = about, concerning; also 'away from.' يبحث عن (yabhath 'an = to search for/about). تحدّث عن (tahaddath 'an = to talk about)."
        }
      ]
    },
    {
      "id": "bi",
      "levels": [
        {
          "front": "with (by means of)",
          "back": "بـ",
          "romanized": "bi-",
          "grammarNote": "بـ (bi-) attaches directly to the next word with no space. بالسيارة (by car), بالعربية (in Arabic), بسرعة (quickly, lit. 'with speed'). Very common preposition."
        }
      ]
    },
    {
      "id": "li",
      "levels": [
        {
          "front": "for",
          "back": "لـ",
          "romanized": "li-",
          "grammarNote": "لـ (li-) attaches to the next word: هذا لك (this is for you), لي (for me/mine). Also appears in lil- (for the): لِلمطعم (for/to the restaurant)."
        }
      ]
    },
    {
      "id": "bayn",
      "levels": [
        {
          "front": "between",
          "back": "بين",
          "romanized": "bayn"
        }
      ]
    },
    {
      "id": "amam",
      "levels": [
        {
          "front": "in front of",
          "back": "أمام",
          "romanized": "amam"
        }
      ]
    },
    {
      "id": "khalf",
      "levels": [
        {
          "front": "behind",
          "back": "خلف",
          "romanized": "khalf"
        }
      ]
    },
    {
      "id": "bi_janib",
      "levels": [
        {
          "front": "next to",
          "back": "بجانب",
          "romanized": "bi-janib"
        }
      ]
    },
    {
      "id": "taht",
      "levels": [
        {
          "front": "under",
          "back": "تحت",
          "romanized": "taht"
        }
      ]
    },
    {
      "id": "fawq",
      "levels": [
        {
          "front": "above",
          "back": "فوق",
          "romanized": "fawq"
        }
      ]
    },
    {
      "id": "keys_in_bag",
      "levels": [
        {
          "front": "The keys are in the bag.",
          "back": "المفاتيح في الحقيبة.",
          "romanized": "al-mafatih fi al-haqiba."
        }
      ]
    },
    {
      "id": "cat_under_table",
      "levels": [
        {
          "front": "The cat is under the table.",
          "back": "القطة تحت الطاولة.",
          "romanized": "al-qitta taht at-tawila."
        }
      ]
    },
    {
      "id": "bank_next_to_cafe",
      "levels": [
        {
          "front": "The bank is next to the cafe.",
          "back": "البنك بجانب المقهى.",
          "romanized": "al-bank bi-janib al-maqha."
        }
      ]
    }
  ]
}