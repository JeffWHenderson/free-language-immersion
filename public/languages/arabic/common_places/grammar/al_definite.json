{
  "id": "al_definite",
  "name": "الـ — The Definite Article",
  "language": "arabic",
  "cards": [
    {
      "id": "al_rule",
      "front": "the (definite article)",
      "back": "الـ",
      "romanized": "al-",
      "grammarNote": "الـ (al-) attaches to the word. Before 'sun letters' (ت د ذ ر ز س ش ص ض ط ظ ل ن), the ل of al- assimilates: الشارع → ash-shāri'. Before 'moon letters' (all others), it stays: البيت → al-bayt."
    },
    {
      "id": "al_madrasa",
      "front": "the school",
      "back": "المدرسة",
      "romanized": "al-madrasa"
    },
    {
      "id": "al_mustashfa",
      "front": "the hospital",
      "back": "المستشفى",
      "romanized": "al-mustashfa"
    },
    {
      "id": "al_mataar",
      "front": "the airport",
      "back": "المطار",
      "romanized": "al-matār"
    },
    {
      "id": "al_funduq",
      "front": "the hotel",
      "back": "الفندق",
      "romanized": "al-funduq"
    },
    {
      "id": "al_maktaba",
      "front": "the library",
      "back": "المكتبة",
      "romanized": "al-maktaba"
    },
    {
      "id": "al_suq",
      "front": "the market",
      "back": "السوق",
      "romanized": "as-sūq",
      "grammarNote": "السوق: س is a sun letter, so al- assimilates to as-. Pronounced as-sūq."
    },
    {
      "id": "al_sharia",
      "front": "the street",
      "back": "الشارع",
      "romanized": "ash-shāri'",
      "grammarNote": "الشارع: ش is a sun letter — al- becomes ash-. Pronounced ash-shāri'."
    },
    {
      "id": "where_hospital",
      "front": "Where is the hospital?",
      "back": "أين المستشفى؟",
      "romanized": "ayn al-mustashfa?",
      "grammarNote": "أين (ayn) = where. Arabic drops 'to be' in the present: just 'where (is) the hospital?'"
    },
    {
      "id": "where_hotel",
      "front": "Where is the hotel?",
      "back": "أين الفندق؟",
      "romanized": "ayn al-funduq?"
    },
    {
