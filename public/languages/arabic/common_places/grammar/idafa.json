{
  "id": "idafa",
  "name": "الإضافة — Noun Possession Construct",
  "language": "arabic",
  "cards": [
    {
      "id": "door_of_house",
      "front": "door of the house",
      "back": "بَابُ الْبَيْتِ",
      "romanized": "bābu l-bayti",
      "grammarNote": "الإضافة (iḍāfa) is the Arabic construct for possession/relationship between two nouns. Rules: (1) the first noun has no article, (2) the second noun is in the genitive case (kasra ending), (3) the first noun's definiteness is determined by the second."
    },
    {
      "id": "center_of_city",
      "front": "center of the city",
      "back": "وَسَطُ الْمَدِينَةِ",
      "romanized": "wasaṭu l-madīnati",
      "grammarNote": "When the second noun has الـ, the entire iḍāfa construct is definite: وَسَطُ الْمَدِينَةِ = the center of the city (definite). Without الـ: وَسَطُ مَدِينَةٍ = a center of a city (indefinite)."
    },
    {
      "id": "station_exit",
      "front": "exit of the station",
      "back": "خُرُوجُ الْمَحَطَّةِ",
      "romanized": "khurūju l-maḥaṭṭati"
    },
    {
      "id": "hotel_key",
      "front": "hotel key",
      "back": "مِفْتَاحُ الْفُنْدُقِ",
      "romanized": "miftāḥu l-funduqi",
      "literal": "key of the hotel"
    },
    {
      "id": "city_center",
      "front": "city center / downtown",
      "back": "مَرْكَزُ الْمَدِينَةِ",
      "romanized": "markazu l-madīnati"
    },
    {
      "id": "airport_entrance",
      "front": "airport entrance",
      "back": "مَدْخَلُ الْمَطَار",
      "romanized": "madkhalu l-maṭār",
      "grammarNote": "A three-word iḍāfa chain is possible: مَدْخَلُ مَطَارِ الْمَدِينَةِ (entrance of the city's airport). Only the very last noun can have الـ or a possessive suffix."
    },
    {
      "id": "street_name",
      "front": "street name",
      "back": "اِسْمُ الشَّارِع",
      "romanized": "ismu l-shāriʿ"
    },
    {
      "id": "bus_stop",
      "front": "bus stop",
      "back": "مَوْقِفُ الْحَافِلَة",
      "romanized": "mawqifu l-ḥāfila"
    },
    {
      "id": "end_of_street",
      "front": "end of the street",
      "back": "نِهَايَةُ الشَّارِع",
      "romanized": "nihāyatu l-shāriʿ"
    },
    {
      "id": "museum_entrance_ticket",
      "front": "museum entrance ticket",
      "back": "تَذْكِرَةُ دُخُولِ الْمُتْحَف",
      "romanized": "tadhkiratu dukhūli l-mutḥaf",
      "grammarNote": "A three-noun iḍāfa chain: تَذْكِرَةُ (ticket of) + دُخُولِ (entrance of) + الْمُتْحَف (the museum). Each intermediate noun is in the genitive, and only the last noun carries الـ."
    },
