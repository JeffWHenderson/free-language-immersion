    {
      "id": "please",
      "levels": [
        {
          "front": "Please",
          "back": "من فضلك / لو سمحت",
          "romanized": "min fadlak / law samaht",
          "grammarNote": "من فضلك (min fadlak) = please (lit. 'from your grace'). لو سمحت (law samaht) = if you would permit. Both are natural — لو سمحت is slightly softer. These forms change by gender/number: فضلك (m.), فضلك (f. = min fadlik), etc."
        },
        {
          "front": "A coffee, please.",
          "back": "قهوة من فضلك.",
          "romanized": "Qahwa min fadlak."
        }
      ]
    },
