    {
      "id": "they",
      "levels": [
        {
          "front": "They",
          "back": "هم / هن",
          "romanized": "hum / hunna",
          "grammarNote": "هم (hum) = they (m. or mixed group). هن (hunna) = they (f. only). In practice, هم is used for mixed or unspecified groups. Arabic also has a dual form (هما, huma) for exactly two people — unique among major world languages."
        },
        {
          "front": "They eat together.",
