{
  "id": "la_negation",
  "name": "لا & ما — Negation",
  "language": "arabic",
  "cards": [
    {
      "id": "la",
      "front": "no / not (general)",
      "back": "لا",
      "romanized": "la",
      "grammarNote": "لا (la) negates nouns and adjectives in equational sentences, and is used for the present tense with verbs in MSA. Also simply means 'no' in response."
    },
    {
      "id": "ma",
      "front": "not (negating present verbs — colloquial)",
      "back": "ما",
      "romanized": "ma",
      "grammarNote": "ما (ma) is common in Egyptian/Levantine Arabic to negate present verbs: ما أعرفش = I don't know. In MSA لا is used for verb negation."
    },
    {
      "id": "lan",
      "front": "will not (future negation)",
      "back": "لن",
      "romanized": "lan",
      "grammarNote": "لن (lan) negates future actions: لن أذهب = I will not go. Requires the subjunctive verb form in MSA."
    },
    {
      "id": "la_arif",
      "front": "I don't know.",
      "back": "لا أعرف.",
      "romanized": "la a'rif.",
      "grammarNote": "لا + present tense verb = 'does not / do not.' Very common in conversation."
    },
    {
      "id": "la_afham",
      "front": "I don't understand.",
      "back": "لا أفهم.",
      "romanized": "la afham."
    },
    {
      "id": "la_atakallam",
      "front": "I don't speak Arabic well.",
      "back": "لا أتكلم العربية جيداً.",
      "romanized": "la atakallam al-arabiyya jayyidan."
    },
    {
      "id": "la_shukran",
      "front": "No, thank you.",
      "back": "لا، شكراً.",
      "romanized": "la, shukran."
    },
    {
      "id": "la_muskila",
      "front": "No problem.",
      "back": "لا مشكلة.",
      "romanized": "la mushkila."
    },
    {
      "id": "la_shay",
      "front": "Nothing / It's nothing.",
      "back": "لا شيء.",
      "romanized": "la shay'."
    },
    {
      "id": "not_hungry",
      "front": "I'm not hungry.",
      "back": "أنا لست جائعاً.",
      "romanized": "ana lastu jai'an.",
      "grammarNote": "لست (lastu) = I am not. لست is the negation of كنت — used to negate 'to be' sentences in past or present formal Arabic."
    },
    {
      "id": "do_not_go",
      "front": "Don't go!",
      "back": "لا تذهب!",
      "romanized": "la tadhhab!",
      "grammarNote": "Prohibition (don't): لا + jussive verb form. لا تذهب (to a man), لا تذهبي (to a woman)."
    },
    {
      "id": "not_far",
      "front": "It's not far.",
      "back": "ليس بعيداً.",
      "romanized": "laysa ba'idan.",
      "grammarNote": "ليس (laysa) = is not. Used to negate nouns and adjectives: ليس + predicate."
    }
  ]
}
