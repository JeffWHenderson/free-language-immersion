    {
      "id": "no_verb_to_be",
      "levels": [{"front": "The coffee is hot. (no verb!)", "back": "القهوة ساخنة.", "romanized": "al-qahwa sakhina.", "grammarNote": "Arabic drops the present-tense verb 'to be.' Simply place the subject next to the predicate. القهوة (the coffee) + ساخنة (hot, fem.) = 'The coffee is hot.' No linking verb needed."}]
    },
    {
      "id": "i_am_hungry",
      "levels": [{"front": "I am hungry.", "back": "أنا جائع.", "romanized": "ana ja'i'.", "grammarNote": "أنا (I) + جائع (hungry, masc.) — the pronoun fills the 'subject' slot and the adjective fills the 'predicate' slot. Female speaker: أنا جائعة (ana ja'ia)."}]
    },
