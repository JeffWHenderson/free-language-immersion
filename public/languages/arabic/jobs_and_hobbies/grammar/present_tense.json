    {
      "id": "i_am_learning",
      "levels": [
        {
          "front": "I am learning Arabic.",
          "back": "أنا أتعلّم العربية.",
          "romanized": "ana ata'allam al-arabiyya.",
          "grammarNote": "Arabic present tense covers both 'I learn' and 'I am learning.' There is no separate progressive form. أتعلّم means both."
        }
      ]
    },
    {
      "id": "verb_root_ktb",
      "levels": [
        {
          "front": "From root ك-ت-ب: book, office, writer, library",
          "back": "كتاب، مكتب، كاتب، مكتبة",
          "romanized": "kitab, maktab, katib, maktaba",
          "grammarNote": "Arabic verbs share roots (جذور, judur) with related nouns. The root ك-ت-ب (k-t-b) relates to writing: كتب (he wrote), يكتب (he writes), كتاب (book), مكتب (office/desk), كاتب (writer), مكتبة (library). Learning roots multiplies vocabulary."
        }
      ]
    }
  ]
