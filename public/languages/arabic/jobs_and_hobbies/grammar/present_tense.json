    {
      "id": "she_speaks",
      "levels": [
        {
          "front": "she speaks Arabic fluently",
          "back": "هي تتكلم العربية بطلاقة.",
          "romanized": "hiya tatakallam al-arabiyya bi-talaqah.",
          "grammarNote": "Note تتكلم for 'she speaks' — both the prefix تـ AND the verb starts with تـ, so you get two تـ: ت (prefix) + تكلم (verb) = تتكلم."
        }
