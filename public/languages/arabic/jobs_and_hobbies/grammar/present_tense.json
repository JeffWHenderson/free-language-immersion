{
  "id": "present_tense",
  "name": "المضارع — Present Tense Verbs",
  "language": "arabic",
  "cards": [
    {
      "id": "i_write",
      "levels": [
        {
          "front": "I write",
          "back": "أكتب",
          "romanized": "aktub",
          "grammarNote": "Present tense prefix for 'I' (أنا) = أـ (a-). So كتب (the root k-t-b) → أكتب (aktub = I write). This prefix applies to all verbs: أذهب (I go), أعمل (I work), أدرس (I study)."
        }
      ]
    },
    {
      "id": "he_writes",
      "levels": [
        {
          "front": "he writes",
          "back": "يكتب",
          "romanized": "yaktub",
          "grammarNote": "Present tense prefix for 'he' (هو) = يـ (y-). يكتب (yaktub = he writes). This same prefix is used for 'they (m.)': يكتبون (yaktubun = they write)."
        }
      ]
    },
    {
      "id": "she_writes",
      "levels": [
        {
          "front": "she writes",
          "back": "تكتب",
          "romanized": "taktub",
          "grammarNote": "Present tense prefix for 'she' (هي) = تـ (t-). Also used for 'you (m.)': تكتب (taktub). Context and the stated pronoun distinguish between 'she writes' and 'you (m.) write.'"
        }
      ]
    },
    {
      "id": "we_write",
      "levels": [
        {
          "front": "we write",
          "back": "نكتب",
          "romanized": "naktub",
          "grammarNote": "Present tense prefix for 'we' (نحن) = نـ (n-). نكتب (naktub = we write). Easy to remember: نحن starts with ن, and so does the verb prefix."
        }
      ]
    },
    {
      "id": "i_go",
