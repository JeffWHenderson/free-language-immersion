    {
      "id": "anti",
      "front": "you (fem.)",
      "back": "أنتِ",
      "romanized": "anti",
      "grammarNote": "Arabic distinguishes masculine and feminine in 2nd person. anta (to a man), anti (to a woman)."
    },
    {
      "id": "huwa",
      "front": "he",
      "back": "هو",
      "romanized": "huwa"
    },
    {
      "id": "hiya",
      "front": "she",
      "back": "هي",
      "romanized": "hiya"
    },
    {
      "id": "nahnu",
      "front": "we",
      "back": "نحن",
      "romanized": "nahnu"
    },
    {
      "id": "i_feel_happy",
      "front": "I feel happy.",
      "back": "أنا أشعر بالسعادة.",
      "romanized": "ana ash'ur bis-sa'ada."
    },
    {
      "id": "he_feels_sad",
      "front": "He feels sad.",
      "back": "هو يشعر بالحزن.",
      "romanized": "huwa yash'ur bil-huzn."
    },
    {
      "id": "she_is_excited",
      "front": "She is excited.",
      "back": "هي متحمسة.",
      "romanized": "hiya mutahamisa."
    },
    {
      "id": "we_are_happy",
      "front": "We are happy today.",
      "back": "نحن سعداء اليوم.",
      "romanized": "nahnu su'ada' al-yawm."
    },
    {
      "id": "how_are_you",
      "front": "How are you? (to a man)",
      "back": "كيف حالك؟",
      "romanized": "kayfa halak?"
    },
    {
      "id": "how_are_you_f",
      "front": "How are you? (to a woman)",
      "back": "كيف حالِك؟",
      "romanized": "kayfa halik?",
      "grammarNote": "The possessive suffix also changes: -ak (masc.) vs -ik (fem.). كيف حالك (to man) / كيف حالِك (to woman)."
    },
    {
      "id": "i_am_fine",
      "front": "I'm fine, praise God.",
      "back": "أنا بخير، الحمد لله.",
      "romanized": "ana bikhyr, al-hamdu lillah.",
      "grammarNote": "بخير (bikhyr) = well/fine. الحمد لله (al-hamdu lillah) = praise be to God — the standard positive response in Arabic."
