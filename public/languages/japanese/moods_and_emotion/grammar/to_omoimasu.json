{
  "id": "to_omoimasu",
  "name": "〜と思います — I Think / I Feel",
  "language": "japanese",
  "cards": [
    {
      "id": "ii_to_omoimasu",
      "front": "I think it's good.",
      "back": "いいと思います。",
      "romanized": "Ii to omoimasu.",
      "grammarNote": "Plain form + と思います = I think that ~. い-adjective: いい → いいと思います. な-adjective: 好きだと思います.",
      "literal": "Good [quote] think."
    },
    {
