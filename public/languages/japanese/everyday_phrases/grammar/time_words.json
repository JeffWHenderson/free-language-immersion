{
  "id": "time_words",
  "name": "Time Words & Days",
  "language": "japanese",
  "cards": [
    {
      "id": "today_tomorrow_yesterday",
      "front": "How do you say 'today', 'tomorrow', and 'yesterday'?",
      "back": "今日（きょう）、明日（あした）、昨日（きのう）",
      "romanized": "kyō, ashita, kinō"
    },
    {
      "id": "now_later",
      "front": "How do you say 'now' and 'later'?",
      "back": "今（いま）、後で（あとで）",
      "romanized": "ima, ato de"
    },
    {
      "id": "morning_afternoon_night",
      "front": "How do you say 'morning', 'afternoon', and 'night'?",
      "back": "朝（あさ）、午後（ごご）、夜（よる）",
      "romanized": "asa, gogo, yoru"
    },
    {
      "id": "what_day_is_today",
      "front": "What day is today? (Ask the question.)",
      "back": "今日は何曜日ですか？",
      "romanized": "Kyō wa nanyōbi desu ka?",
      "grammarNote": "何曜日 (nanyōbi) = what day of the week."
    },
    {
      "id": "monday_friday",
      "front": "How do you say Monday and Friday?",
      "back": "月曜日（げつようび）、金曜日（きんようび）",
      "romanized": "Getsuyōbi, Kin'yōbi"
    },
    {
      "id": "saturday_sunday",
      "front": "How do you say Saturday and Sunday?",
      "back": "土曜日（どようび）、日曜日（にちようび）",
      "romanized": "Doyōbi, Nichiyōbi"
    },
    {
      "id": "today_go_school",
      "front": "Today I go to school.",
      "back": "今日は学校に行きます。",
      "romanized": "Kyō wa gakkō ni ikimasu.",
      "grammarNote": "Time expressions come before the verb, typically near the start: Time → Place → Verb."
    },
    {
      "id": "yesterday_watched_movie",
      "front": "Yesterday I watched a movie.",
      "back": "昨日、映画を見ました。",
      "romanized": "Kinō, eiga wo mimashita."
    },
    {
      "id": "every_day",
      "front": "How do you say 'every day'?",
      "back": "毎日（まいにち）",
      "romanized": "mainichi",
      "grammarNote": "毎 (mai) = every. 毎朝 (maiasa) = every morning, 毎週 (maishū) = every week."
    },
    {
      "id": "sometimes_always",
      "front": "How do you say 'sometimes' and 'always'?",
      "back": "時々（ときどき）、いつも",
      "romanized": "tokidoki, itsumo"
    },
    {
      "id": "not_often",
      "front": "I don't go often. (Use 'not often.')",
      "back": "あまり行きません。",
      "romanized": "Amari ikimasen.",
      "grammarNote": "あまり requires a negative verb: あまり〜ません (not much/not often)."
    },
    {
      "id": "not_at_all",
      "front": "I don't understand at all.",
      "back": "全然わかりません。",
      "romanized": "Zenzen wakarimasen.",
      "grammarNote": "全然〜ない = not at all / never. Always paired with a negative verb form."
    }
  ]
}
