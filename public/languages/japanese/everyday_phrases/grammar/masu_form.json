{
  "id": "masu_form",
  "name": "〜ます Verb Form",
  "language": "japanese",
  "cards": [
    {
      "id": "wakarimasu",
      "front": "understand",
      "back": "わかります",
      "romanized": "wakarimasu",
      "grammarNote": "わかる → わかります (Group 1). Very common in conversation: わかりますか？ (Do you understand?)"
    },
    {
      "id": "wakarimasen",
      "front": "I don't understand.",
      "back": "わかりません。",
      "romanized": "Wakarimasen.",
      "grammarNote": "Negative ます: replace ます with ません."
    },
    {
      "id": "imasu",
      "front": "be (animate)",
      "back": "います",
      "romanized": "imasu",
      "grammarNote": "いる → います. Use います for people and animals. For objects use あります (arimasu)."
    },
    {
      "id": "hanashimasu",
      "front": "speak",
      "back": "はなします",
      "romanized": "hanashimasu",
      "grammarNote": "はなす → はなします (Group 1: す → し + ます)."
    },
    {
      "id": "kikimasu",
      "front": "listen / hear",
      "back": "ききます",
      "romanized": "kikimasu",
      "grammarNote": "きく → ききます (Group 1: く → き + ます)."
    },
    {
      "id": "mimasu",
      "front": "see / look",
      "back": "みます",
      "romanized": "mimasu",
      "grammarNote": "みる → みます (Group 2: drop る, add ます)."
    },
    {
      "id": "do_you_understand",
      "front": "Do you understand?",
      "back": "わかりますか？",
      "romanized": "Wakarimasu ka?"
    },
    {
      "id": "do_you_speak_english",
      "front": "Do you speak English?",
      "back": "えいごをはなしますか？",
      "romanized": "Eigo wo hanashimasu ka?"
    },
    {
      "id": "i_understand_a_little",
      "front": "I understand a little.",
      "back": "すこしわかります。",
      "romanized": "Sukoshi wakarimasu."
    },
    {
      "id": "please_listen",
      "front": "Please listen.",
      "back": "きいてください。",
      "romanized": "Kiite kudasai.",
      "grammarNote": "て-form + ください = please do X. きく → きいて + ください."
    },
    {
      "id": "i_can_see_it",
      "front": "I can see it.",
      "back": "みえます。",
      "romanized": "Miemasu.",
      "grammarNote": "みえる (mieru) = to be visible / can see. Different from みる (to look)."
    },
    {
      "id": "speak_slowly",
      "front": "Please speak slowly.",
      "back": "ゆっくりはなしてください。",
      "romanized": "Yukkuri hanashite kudasai."
    },
    {
      "id": "again_please",
      "front": "Please say that again.",
      "back": "もういちどいってください。",
      "romanized": "Mō ichido itte kudasai."
    }
  ]
}
