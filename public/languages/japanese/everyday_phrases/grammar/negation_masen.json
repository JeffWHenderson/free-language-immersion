{
  "id": "negation_masen",
  "name": "〜ません — Polite Negative",
  "language": "japanese",
  "cards": [
    {
      "id": "tabemasen",
      "front": "I don't eat meat.",
      "back": "肉を食べません。",
      "romanized": "Niku wo tabemasen.",
      "grammarNote": "Polite negative: replace ます with ません. 食べます → 食べません.",
      "literal": "Meat [obj] don't-eat."
    },
    {
      "id": "ikimasen",
      "front": "I don't go to school on weekends.",
      "back": "週末に学校に行きません。",
      "romanized": "Shūmatsu ni gakkō ni ikimasen.",
      "literal": "Weekends on school to don't-go."
    },
    {
      "id": "wakarimasen",
      "front": "I don't understand.",
      "back": "わかりません。",
      "romanized": "Wakarimasen.",
      "grammarNote": "わかりません is one of the most essential phrases. Use it when you don't understand something said to you.",
      "literal": "Don't understand."
    },
    {
      "id": "nomimasen",
      "front": "I don't drink alcohol.",
      "back": "お酒を飲みません。",
      "romanized": "Osake wo nomimasen.",
      "literal": "Alcohol [obj] don't-drink."
    },
    {
      "id": "shirimasen",
      "front": "I don't know.",
      "back": "知りません。",
      "romanized": "Shirimasen.",
      "grammarNote": "知りません = I don't know (a fact). わかりません = I don't understand. Both are negatives but used in different contexts.",
      "literal": "Don't know."
    },
    {
      "id": "hanashimasen",
      "front": "I don't speak French.",
      "back": "フランス語を話しません。",
      "romanized": "Furansugo wo hanashimasen.",
      "literal": "French [obj] don't-speak."
    },
    {
      "id": "mimasen",
      "front": "I don't watch TV much.",
      "back": "あまりテレビを見ません。",
      "romanized": "Amari terebi wo mimasen.",
      "grammarNote": "あまり〜ません = don't do X much. あまり softens the negation.",
      "literal": "Much TV [obj] don't-watch."
    },
    {
      "id": "gakusei_ja_arimasen",
      "front": "I'm not a student.",
      "back": "学生じゃありません。",
      "romanized": "Gakusei ja arimasen.",
      "grammarNote": "For noun/na-adjective negation: じゃありません (or ではありません, more formal). This is different from verb negation with ません.",
      "literal": "Student not-am."
    },
    {
      "id": "sensei_ja_arimasen",
      "front": "She is not a teacher.",
      "back": "先生じゃありません。",
      "romanized": "Sensei ja arimasen.",
      "literal": "Teacher not-is."
    },
    {
      "id": "suki_ja_arimasen",
      "front": "I don't like spicy food.",
      "back": "辛い食べ物が好きじゃありません。",
      "romanized": "Karai tabemono ga suki ja arimasen.",
      "grammarNote": "好き (suki) is a na-adjective, so negate with じゃありません: 好きじゃありません.",
      "literal": "Spicy food [subj] liked not-am."
    },
    {
      "id": "zenzen_wakarimasen",
      "front": "I don't understand at all.",
      "back": "全然わかりません。",
      "romanized": "Zenzen wakarimasen.",
      "grammarNote": "全然〜ません = don't do X at all. 全然 requires a negative ending.",
      "literal": "At-all don't-understand."
    },
    {
      "id": "mada_kimasen",
      "front": "He hasn't come yet.",
      "back": "まだ来ません。",
      "romanized": "Mada kimasen.",
      "grammarNote": "まだ〜ません = not yet. まだ来ていません is also very common and slightly more natural.",
      "literal": "Still/yet don't-come."
    }
  ]
}
