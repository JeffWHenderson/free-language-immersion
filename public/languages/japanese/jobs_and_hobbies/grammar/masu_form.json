  "cards": [
    {
      "id": "i_study_everyday",
      "levels": [{"front": "I study every day.", "back": "まいにちべんきょうします。", "romanized": "Mainichi benkyō shimasu.", "grammarNote": "します (shimasu) is the ます-form of する (suru). する + ます = します. Use します with nouns to form verb phrases: 勉強します, 運動します."}]
    },
    {
      "id": "i_eat_breakfast",
      "levels": [{"front": "I eat breakfast.", "back": "あさごはんをたべます。", "romanized": "Asagohan wo tabemasu.", "grammarNote": "たべる → たべます (Group 2 / Ru-verb: drop る, add ます)."}]
    },
    {
      "id": "i_drink_coffee",
      "levels": [{"front": "I drink coffee.", "back": "コーヒーをのみます。", "romanized": "Kōhī wo nomimasu.", "grammarNote": "のむ → のみます (Group 1 / U-verb: む → み + ます)."}]
    },
    {
