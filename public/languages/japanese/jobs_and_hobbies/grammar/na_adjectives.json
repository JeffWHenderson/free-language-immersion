{
  "id": "na_adjectives",
  "name": "な-Adjectives",
  "language": "japanese",
  "cards": [
    {
      "id": "suki",
      "front": "liked / favourite",
      "back": "すきです",
      "romanized": "suki desu",
      "grammarNote": "すき is a な-adjective. To say you like something: X が すきです (I like X). The thing liked takes が, not を."
    },
    {
      "id": "kirai",
      "front": "disliked",
      "back": "きらいです",
      "romanized": "kirai desu",
      "grammarNote": "きらい also takes が for the thing disliked: にんじんがきらいです = I dislike carrots."
    },
    {
      "id": "jozu",
      "front": "skilled / good at",
      "back": "じょうずです",
      "romanized": "jōzu desu",
      "grammarNote": "じょうず takes が for the skill: えいごがじょうずです = good at English. Use へた for 'not skilled at'."
    },
    {
      "id": "heta",
      "front": "unskilled / bad at",
      "back": "へたです",
      "romanized": "heta desu"
    },
    {
      "id": "shizuka",
      "front": "quiet",
      "back": "しずかです",
      "romanized": "shizuka desu"
    },
    {
      "id": "nigiyaka",
      "front": "lively / busy (atmosphere)",
      "back": "にぎやかです",
      "romanized": "nigiyaka desu"
    },
    {
      "id": "taisetsu",
      "front": "important",
      "back": "たいせつです",
      "romanized": "taisetsu desu"
    },
    {
      "id": "i_like_cooking",
      "front": "I like cooking.",
      "back": "りょうりがすきです。",
      "romanized": "Ryōri ga suki desu."
    },
    {
      "id": "she_good_at_sports",
      "front": "She's good at sports.",
      "back": "かのじょはスポーツがじょうずです。",
      "romanized": "Kanojo wa supōtsu ga jōzu desu."
    },
    {
      "id": "i_like_music",
      "front": "I like music.",
      "back": "おんがくがすきです。",
      "romanized": "Ongaku ga suki desu."
    },
    {
      "id": "na_before_noun",
      "front": "a quiet place",
      "back": "しずかなところ",
      "romanized": "shizuka na tokoro",
      "grammarNote": "な-adjectives use な before nouns: しずかな + ところ = a quiet place."
    },
    {
      "id": "negative_suki",
      "front": "I don't like it.",
      "back": "すきじゃないです。",
      "romanized": "Suki ja nai desu.",
      "grammarNote": "Negative: じゃない (ja nai) = is not. Casual form of ではない."
