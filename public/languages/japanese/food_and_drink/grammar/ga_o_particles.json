  "name": "が & を — Subject & Object Particles",
  "language": "japanese",
  "cards": [
    {
      "id": "i_eat_bread",
      "front": "I eat bread.",
      "back": "パンをたべます。",
      "romanized": "Pan wo tabemasu.",
      "grammarNote": "を (wo/o) marks the direct object — the thing being eaten, drunk, or acted upon."
    },
    {
      "id": "i_drink_water",
      "front": "I drink water.",
      "back": "みずをのみます。",
      "romanized": "Mizu wo nomimasu."
