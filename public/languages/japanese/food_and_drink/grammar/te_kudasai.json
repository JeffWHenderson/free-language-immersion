{
  "id": "te_kudasai",
  "name": "〜てください — Please Do",
  "language": "japanese",
  "cards": [
    {
      "id": "te_kudasai",
      "front": "Please do X.",
      "back": "〜てください",
      "romanized": "~te kudasai",
      "grammarNote": "て-form + ください = a polite request: 'please do X.' Use this to order food, make requests, or give polite instructions."
    },
    {
      "id": "kore_wo_kudasai",
      "front": "This one, please. (ordering)",
      "back": "これをください。",
      "romanized": "Kore wo kudasai.",
      "grammarNote": "ください alone (without the て-form) means 'please give me'. Use with nouns to order food or items."
    },
    {
      "id": "mizu_kudasai",
      "front": "Water, please.",
      "back": "みずをください。",
      "romanized": "Mizu wo kudasai."
    },
    {
      "id": "menu_please",
      "front": "The menu, please.",
      "back": "メニューをください。",
      "romanized": "Menyū wo kudasai."
    },
    {
      "id": "mite_kudasai",
      "front": "Please look (at this).",
      "back": "みてください。",
      "romanized": "Mite kudasai.",
      "grammarNote": "みる → みて + ください (Group 2 て-form: drop る, add て)."
    },
    {
      "id": "matte_kudasai",
      "front": "Please wait.",
      "back": "まってください。",
      "romanized": "Matte kudasai.",
      "grammarNote": "まつ → まって + ください (Group 1 て-form: つ → って)."
    },
    {
      "id": "oshiete_kudasai",
      "front": "Please tell me / teach me.",
      "back": "おしえてください。",
      "romanized": "Oshiete kudasai.",
      "grammarNote": "おしえる → おしえて + ください (Group 2: drop る, add て)."
    },
    {
      "id": "please_say_again",
      "front": "Please say it again.",
      "back": "もういちどいってください。",
      "romanized": "Mō ichido itte kudasai."
    },
    {
      "id": "hitotsu_kudasai",
      "front": "One of these, please.",
      "back": "ひとつください。",
      "romanized": "Hitotsu kudasai."
    },
    {
      "id": "okaike_please",
      "front": "The check, please.",
      "back": "おかいけいをください。",
      "romanized": "Okaikei wo kudasai."
    },
    {
      "id": "kaite_kudasai",
      "front": "Please write it down.",
      "back": "かいてください。",
      "romanized": "Kaite kudasai.",
      "grammarNote": "かく → かいて + ください (Group 1: く → いて)."
    },
    {
      "id": "soto_de_tabete",
      "front": "I'd like this to go, please.",
      "back": "もちかえりでおねがいします。",
      "romanized": "Mochikaeri de onegai shimasu.",
      "grammarNote": "おねがいします = please (formal request). More polite than ください for service contexts."
    }
  ]
}
