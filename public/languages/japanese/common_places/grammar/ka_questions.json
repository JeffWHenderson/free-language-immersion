{
  "id": "ka_questions",
  "name": "か — Yes/No Questions",
  "language": "japanese",
  "cards": [
    {
      "id": "ka_particle",
      "front": "question marker",
      "back": "か",
      "romanized": "ka",
      "grammarNote": "Add か to the end of any polite sentence to form a yes/no question. Spoken Japanese often uses rising intonation without か in casual speech."
    },
    {
      "id": "is_there_station",
      "front": "Is there a train station?",
      "back": "えきはありますか？",
      "romanized": "Eki wa arimasu ka?"
    },
    {
      "id": "is_it_near",
      "front": "Is it near?",
      "back": "ちかいですか？",
      "romanized": "Chikai desu ka?"
    },
    {
      "id": "is_this_the_bus",
      "front": "Is this the bus to the airport?",
      "back": "このバスはくうこうにいきますか？",
      "romanized": "Kono basu wa kūkō ni ikimasu ka?"
    },
    {
      "id": "do_you_know_the_way",
      "front": "Do you know the way?",
      "back": "みちをしっていますか？",
      "romanized": "Michi wo shitte imasu ka?",
      "grammarNote": "しっています = know (lit. 'am knowing'). Knowledge/states use the ている form."
    },
    {
      "id": "is_there_a_bathroom",
      "front": "Is there a bathroom?",
      "back": "トイレはありますか？",
      "romanized": "Toire wa arimasu ka?"
    },
    {
      "id": "is_it_open",
      "front": "Is it open?",
      "back": "あいていますか？",
      "romanized": "Aite imasu ka?",
      "grammarNote": "あいている = is open (state). Add か for question."
    },
    {
      "id": "are_you_going",
      "front": "Are you going to Tokyo?",
      "back": "とうきょうにいきますか？",
      "romanized": "Tōkyō ni ikimasu ka?"
    },
    {
      "id": "is_this_correct",
      "front": "Is this right? (direction)",
      "back": "このほうこうであっていますか？",
      "romanized": "Kono hōkō de atte imasu ka?"
    },
    {
      "id": "yes_that_is_right",
      "front": "Yes, that's right.",
      "back": "はい、そうです。",
      "romanized": "Hai, sō desu.",
      "grammarNote": "はい = yes. そうです = that's right. Common answer to confirmation questions."
    },
    {
      "id": "no_different",
      "front": "No, it's different.",
      "back": "いいえ、ちがいます。",
      "romanized": "Iie, chigaimasu.",
      "grammarNote": "いいえ = no. ちがいます = it's different / that's wrong."
    },
    {
      "id": "how_far",
      "front": "How far is it?",
      "back": "どのくらいとおいですか？",
      "romanized": "Dono kurai tōi desu ka?"
    }
  ]
}
