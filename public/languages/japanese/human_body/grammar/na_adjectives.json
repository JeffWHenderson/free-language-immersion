{
  "id": "na_adjectives",
  "name": "な-Adjectives",
  "language": "japanese",
  "cards": [
    {
      "id": "genki",
      "front": "healthy / energetic",
      "back": "げんきです",
      "romanized": "genki desu",
      "grammarNote": "な-adjectives use な when modifying nouns (げんきなひと = healthy person) but drop な before です."
    },
    {
      "id": "byoki",
      "front": "sick / ill",
      "back": "びょうきです",
      "romanized": "byōki desu",
      "grammarNote": "びょうき is a noun used as a predicate. びょうきです = I am sick. びょうきのひと = a sick person."
    },
    {
      "id": "daijoubu",
      "front": "fine / okay",
      "back": "だいじょうぶです",
      "romanized": "daijōbu desu",
      "grammarNote": "だいじょうぶ is extremely common: 'Are you okay?' (だいじょうぶですか？) and 'It's fine / No thanks' (だいじょうぶです)."
    },
    {
      "id": "shinpai",
      "front": "worried",
      "back": "しんぱいです",
      "romanized": "shinpai desu"
    },
    {
      "id": "hima",
      "front": "free (not busy) / bored",
      "back": "ひまです",
      "romanized": "hima desu"
    },
    {
      "id": "are_you_okay",
      "front": "Are you okay?",
      "back": "だいじょうぶですか？",
      "romanized": "Daijōbu desu ka?"
    },
    {
      "id": "i_am_fine",
      "front": "I'm fine, thank you.",
      "back": "だいじょうぶです、ありがとうございます。",
      "romanized": "Daijōbu desu, arigatō gozaimasu."
    },
    {
      "id": "i_am_sick",
      "front": "I am sick today.",
      "back": "きょうはびょうきです。",
      "romanized": "Kyō wa byōki desu."
    },
    {
      "id": "are_you_healthy",
      "front": "Are you doing well?",
      "back": "おげんきですか？",
      "romanized": "Ogenki desu ka?",
      "grammarNote": "お + げんき = polite/honorific form. おげんきですか is the standard 'How are you?' greeting."
    },
    {
      "id": "not_well",
      "front": "I'm not doing well.",
      "back": "げんきじゃないです。",
      "romanized": "Genki ja nai desu.",
      "grammarNote": "Negative: replace です with じゃないです (or ではないです, more formal)."
    },
    {
      "id": "was_healthy",
      "front": "I was healthy before.",
      "back": "まえはげんきでした。",
      "romanized": "Mae wa genki deshita.",
      "grammarNote": "Past: replace です with でした."
    },
    {
      "id": "healthy_person",
      "front": "a healthy person",
      "back": "げんきなひと",
      "romanized": "genki na hito",
      "grammarNote": "な-adjectives use な before a noun: げんきな + ひと = a healthy person."
    }
  ]
}
