  "cards": [
    {
      "id": "itai",
      "front": "painful / ouch",
      "back": "いたいです",
      "romanized": "itai desu",
      "grammarNote": "いたい (itai) = it hurts / painful. More specific: 〜が いたい = my X hurts. あたまがいたい = my head hurts."
    },
    {
      "id": "tsukare",
      "front": "tired",
      "back": "つかれました",
      "romanized": "tsukaremashita",
      "grammarNote": "つかれる → つかれました (past). In Japanese, tiredness is expressed in the past form (the state of having become tired)."
    },
    {
      "id": "kayui",
      "front": "itchy",
      "back": "かゆいです",
      "romanized": "kayui desu"
    },
    {
