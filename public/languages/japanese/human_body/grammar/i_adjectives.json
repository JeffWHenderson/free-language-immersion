      "front": "heavy",
      "back": "おもいです",
      "romanized": "omoi desu"
    },
    {
      "id": "karui",
      "front": "light (not heavy)",
      "back": "かるいです",
      "romanized": "karui desu"
    },
    {
      "id": "atama_ga_itai",
      "front": "My head hurts.",
      "back": "あたまがいたいです。",
      "romanized": "Atama ga itai desu.",
      "grammarNote": "が marks the body part that hurts as the grammatical subject. This is different from English — the pain is the subject experiencing the person."
    },
    {
      "id": "nodo_ga_itai",
      "front": "My throat hurts.",
      "back": "のどがいたいです。",
      "romanized": "Nodo ga itai desu."
