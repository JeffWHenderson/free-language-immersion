    {
      "id": "onaka_ga_itai",
      "front": "My stomach hurts.",
      "back": "おなかがいたいです。",
      "romanized": "Onaka ga itai desu."
    },
    {
      "id": "totemo_itai",
      "front": "It really hurts.",
      "back": "とてもいたいです。",
      "romanized": "Totemo itai desu."
    },
    {
      "id": "not_painful",
      "front": "It doesn't hurt.",
      "back": "いたくないです。",
      "romanized": "Itakunai desu.",
      "grammarNote": "Negative: い → くない. いたい → いたくない."
