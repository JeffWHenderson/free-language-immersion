{
  "id": "te_kudasai",
  "name": "〜てください — Please Do",
  "language": "japanese",
  "cards": [
    {
      "id": "please_wait",
      "front": "Please wait.",
      "back": "まってください。",
      "romanized": "Matte kudasai.",
      "grammarNote": "Te-form + ください is the standard polite request. まつ → まって (Group 1: つ → って)."
    },
    {
      "id": "please_speak_slowly",
      "front": "Please speak slowly.",
      "back": "ゆっくりはなしてください。",
      "romanized": "Yukkuri hanashite kudasai.",
      "grammarNote": "はなす → はなして (Group 1: す → して). Add adverbs before the te-form."
    },
    {
      "id": "please_sit_here",
      "front": "Please sit here.",
      "back": "ここにすわってください。",
      "romanized": "Koko ni suwatte kudasai."
    },
    {
      "id": "please_say_again",
      "front": "Please say it one more time.",
      "back": "もういちどいってください。",
      "romanized": "Mō ichido itte kudasai.",
      "grammarNote": "いく → いって (special irregular: not いいて)."
    },
    {
      "id": "please_write_name",
      "front": "Please write your name.",
      "back": "なまえをかいてください。",
      "romanized": "Namae wo kaite kudasai.",
      "grammarNote": "かく → かいて (Group 1: く → いて)."
    },
    {
      "id": "please_open_window",
      "front": "Please open the window.",
      "back": "まどをあけてください。",
      "romanized": "Mado wo akete kudasai.",
      "grammarNote": "あける → あけて (Group 2 / Ru-verb: drop る, add て)."
    },
    {
      "id": "please_wash_hands",
      "front": "Please wash your hands.",
      "back": "てをあらってください。",
      "romanized": "Te wo aratte kudasai.",
      "grammarNote": "あらう → あらって (Group 1: う → って)."
    },
    {
      "id": "please_show_me",
      "front": "Please show me.",
      "back": "みせてください。",
      "romanized": "Misete kudasai."
    },
    {
      "id": "please_come",
      "front": "Please come here.",
      "back": "ここにきてください。",
      "romanized": "Koko ni kite kudasai.",
      "grammarNote": "くる → きて (irregular Group 3)."
    },
    {
      "id": "please_read_this",
      "front": "Please read this.",
      "back": "これをよんでください。",
      "romanized": "Kore wo yonde kudasai.",
      "grammarNote": "よむ → よんで (Group 1: む → んで)."
    },
    {
      "id": "please_do_not_enter",
      "front": "Please do not enter.",
      "back": "はいらないでください。",
      "romanized": "Hairanaide kudasai.",
      "grammarNote": "Negative request: negative plain form (ない-form) + でください. はいる → はいらない → はいらないで + ください."
    },
    {
      "id": "please_do_not_take_photos",
      "front": "Please do not take photos.",
      "back": "しゃしんをとらないでください。",
      "romanized": "Shashin wo toranaide kudasai."
    },
    {
      "id": "please_be_quiet",
      "front": "Please be quiet.",
      "back": "しずかにしてください。",
      "romanized": "Shizuka ni shite kudasai.",
      "grammarNote": "する → して (irregular). しずかに + してください = please be quiet."
    },
    {
      "id": "could_you_wait",
      "front": "Could you wait?",
      "back": "まってもらえますか？",
      "romanized": "Matte moraemasu ka?",
      "grammarNote": "〜てもらえますか is a softer, more polite alternative to 〜てください."
    },
    {
      "id": "please_open_mouth",
      "front": "Please open your mouth.",
      "back": "くちをあけてください。",
      "romanized": "Kuchi wo akete kudasai."
    },
    {
      "id": "please_breathe_slowly",
      "front": "Please breathe slowly.",
      "back": "ゆっくりこきゅうしてください。",
      "romanized": "Yukkuri kokyū shite kudasai."
    },
    {
      "id": "please_dont_be_late",
      "front": "Please don't be late.",
      "back": "おそくならないでください。",
      "romanized": "Osoku naranaide kudasai."
    }
  ]
}
