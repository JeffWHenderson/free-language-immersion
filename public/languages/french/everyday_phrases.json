    "good_morning": {
      "levels": [
        {
          "front": "Good morning",
          "back": "bonjour",
          "grammarNote": "bonjour covers both 'good morning' and 'good afternoon'. bonsoir = good evening (from around 6pm). bonne nuit = good night (only when going to bed). In France, saying bonjour when entering a shop is expected."
