    "you": {
      "levels": [
        {
          "front": "You",
          "back": "tu / vous",
          "grammarNote": "tu = informal (one person, someone you know). vous = formal or plural. Using tu with a stranger can feel rude; using vous is always safe. The switch from vous to tu (tutoyer) is a social milestone in French relationships."
        },
        {
          "front": "You speak French well.",
          "back": "Tu parles bien français."
        }
      ]
    },
