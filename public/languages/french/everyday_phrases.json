    "it": {
      "levels": [
        {
          "front": "It",
          "back": "il / elle / ça",
          "grammarNote": "French has no neutral pronoun — every noun is masculine (il) or feminine (elle). For abstract ideas or pointing at things: ça (that/it). C'est ça = 'that's it / exactly'."
        },
        {
          "front": "That's it / It's fine.",
          "back": "C'est ça. / Ça va."
        }
      ]
    },
    "we": {
      "levels": [
        {
          "front": "We",
          "back": "nous / on",
          "grammarNote": "on is used conversationally to mean 'we' in spoken French — more common than nous in everyday speech. 'On mange ensemble' (we eat together). on takes the same verb form as il/elle."
        },
        {
          "front": "We live here.",
          "back": "On habite ici."
        }
      ]
    },
