    "i_need": {
      "levels": [
        {
          "front": "I need",
          "back": "j'ai besoin de",
          "grammarNote": "avoir besoin de = 'to need' — literally 'to have need of'. j'ai besoin d'aide (I need help), j'ai besoin de temps (I need time). The de contracts with a following vowel: besoin d'aide."
        },
