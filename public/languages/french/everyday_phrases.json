    "my_name_is": {
      "levels": [
        {
          "front": "My name is",
          "back": "je m'appelle",
          "grammarNote": "je m'appelle uses the reflexive verb s'appeler — literally 'I call myself'. Much more natural than 'mon nom est'. The double l in appelle is a spelling quirk to preserve the /ɛl/ sound."
        },
        {
          "front": "My name is Marie.",
          "back": "Je m'appelle Marie."
        }
      ]
    },
