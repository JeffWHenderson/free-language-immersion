  "cards": [
    {
      "id": "head",
      "english": "head",
      "word": "la tête",
      "grammarNote": "To express pain in French, use 'avoir mal à + body part': j'ai mal à la tête (my head hurts), j'ai mal au dos (my back hurts), j'ai mal aux pieds (my feet hurt). The article contracts: à + le = au, à + les = aux.",
      "englishPhrase": "My head hurts.",
      "phrase": "J'ai mal à la tête."
    },
    {
      "id": "hair",
      "english": "hair",
      "word": "les cheveux (masc.)",
      "grammarNote": "'Les cheveux' is always plural in French (the collection of hair). One strand is 'un cheveu'. 'Elle a les cheveux longs' = She has long hair. Note: use the definite article with body parts, not possessives — 'elle a les cheveux courts', not 'ses cheveux courts'.",
      "englishPhrase": "She has long hair.",
      "phrase": "Elle a les cheveux longs."
    },
    {
      "id": "face",
