{
  "id": "hay",
  "name": "Hay — There Is / There Are",
  "language": "spanish",
  "cards": [
    {
      "id": "hay",
      "front": "there is / there are",
      "back": "hay",
      "grammarNote": "Hay is invariable — it doesn't change for singular or plural."
    },
    {
      "id": "hay_que",
      "front": "one must / you need to",
      "back": "hay que",
      "grammarNote": "Hay + que + infinitive = 'it is necessary to'. Impersonal — commonly used for medical advice."
    },
    {
