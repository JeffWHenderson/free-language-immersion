{
  "id": "doler",
  "name": "Doler — To Hurt",
  "language": "spanish",
  "cards": [
    {
      "id": "doler",
      "front": "to hurt",
      "back": "doler",
      "grammarNote": "Works like gustar — the body part is the subject, you are the indirect object."
    },
    {
      "id": "me_duele",
      "front": "my ___ hurts (singular)",
      "back": "me duele",
      "grammarNote": "Me = to me. Duele = hurts (singular subject)."
    },
    {
      "id": "me_duelen",
      "front": "my ___ hurt (plural)",
      "back": "me duelen",
      "grammarNote": "Duelen = hurt (plural subject, e.g. my feet)."
    },
    {
      "id": "te_duele",
      "front": "your ___ hurts",
      "back": "te duele"
    },
