    {
      "id": "happy",
      "levels": [
        {"front": "happy", "back": "feliz", "grammarNote": "Adverb form: felizmente (happily). Spanish adverbs are made by adding -mente to the feminine adjective. Feliz has no gender change: feliz + mente → felizmente. E.g., 'Ella sonrió felizmente.' (She smiled happily.)"},
        {"front": "I'm very happy today.", "back": "Estoy muy feliz hoy.", "literal": "[I] am very happy today."}
      ]
    },
