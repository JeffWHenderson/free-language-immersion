{
  "id": "ser_vs_estar",
  "name": "Ser vs. Estar",
  "language": "spanish",
  "cards": [
    {
      "id": "ser_perm",
      "front": "to be (identity)",
      "back": "ser",
      "grammarNote": "Use for who you are, where you're from, your profession, and inherent traits."
    },
    {
      "id": "estar_temp",
      "front": "to be (state)",
      "back": "estar",
      "grammarNote": "Use for how you feel, where you are, and temporary conditions."
    },
    {
      "id": "soy_feliz",
      "front": "I am a happy person. (personality)",
      "back": "Soy feliz.",
      "grammarNote": "Ser = permanent personality trait."
    },
    {
      "id": "estoy_feliz",
      "front": "I am happy right now. (current mood)",
      "back": "Estoy feliz.",
      "grammarNote": "Estar = current emotional state."
    },
    {
      "id": "es_nerviosa",
      "front": "She is a nervous person.",
      "back": "Ella es nerviosa.",
      "grammarNote": "Ser = it's part of her personality."
    },
    {
      "id": "esta_nerviosa",
      "front": "She is nervous right now.",
      "back": "Ella está nerviosa.",
      "grammarNote": "Estar = how she feels at this moment."
    },
    {
      "id": "soy_de",
      "front": "I am from Spain.",
      "back": "Soy de España.",
      "grammarNote": "Ser = origin."
    },
    {
      "id": "estoy_en",
      "front": "I am in Spain.",
      "back": "Estoy en España.",
      "grammarNote": "Estar = location."
    },
    {
      "id": "cafe_amargo",
      "front": "Coffee is bitter. (by nature)",
      "back": "El café es amargo.",
      "grammarNote": "Ser = inherent characteristic."
    },
    {
      "id": "cafe_frio",
      "front": "The coffee is cold. (right now)",
      "back": "El café está frío.",
      "grammarNote": "Estar = current temporary state."
    },
    {
      "id": "como_eres",
      "front": "What are you like?",
      "back": "¿Cómo eres?",
      "grammarNote": "Asks about personality — uses ser."
    },
    {
      "id": "como_estas",
      "front": "How are you?",
      "back": "¿Cómo estás?",
      "grammarNote": "Asks about current state — uses estar."
    },
    {
      "id": "soy_alto",
      "front": "I am tall and dark-haired.",
      "back": "Soy alto y moreno."
    },
    {
      "id": "estoy_ocupado",
      "front": "I am very busy today.",
      "back": "Estoy muy ocupado hoy."
    },
    {
      "id": "es_medico",
      "front": "He is a doctor.",
      "back": "Él es médico.",
      "grammarNote": "Ser = profession."
    },
    {
      "id": "esta_cansado",
      "front": "He is tired.",
      "back": "Él está cansado.",
      "grammarNote": "Estar = current physical condition."
    },
    {
      "id": "puerta_abierta",
      "front": "The door is open.",
      "back": "La puerta está abierta.",
      "grammarNote": "Estar = result of an action / current state."
    }
  ]
}
