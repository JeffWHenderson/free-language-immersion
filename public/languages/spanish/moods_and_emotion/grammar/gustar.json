      "back": "Me gusta estar bien."
    },
    {
      "id": "que_te_gusta_hacer",
      "front": "What do you like to do to feel better?",
      "back": "¿Qué te gusta hacer para sentirte mejor?"
    },
    {
      "id": "le_gusta_la_calma",
      "front": "She likes calm environments.",
      "back": "Le gusta la tranquilidad."
    },
    {
      "id": "me_gusta_reir",
      "front": "I like laughing.",
      "back": "Me gusta reír."
    }
  ]
