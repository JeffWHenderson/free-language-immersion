{
  "id": "gustar",
  "name": "Gustar — I Like",
  "language": "spanish",
  "cards": [
    {
      "id": "me_gusta",
      "front": "I like",
      "back": "me gusta",
      "grammarNote": "Gustar works backwards — the thing you like is the grammatical subject. 'Me gusta la música' = literally 'the music pleases me.'"
    },
    {
      "id": "me_gustan",
      "front": "I like (plural things)",
      "back": "me gustan"
    },
    {
      "id": "te_gusta",
      "front": "you like",
      "back": "te gusta"
    },
    {
      "id": "le_encanta",
      "front": "he/she loves",
      "back": "le encanta"
    },
    {
      "id": "me_gusta_musica",
      "front": "I like music.",
      "back": "Me gusta la música."
    },
    {
      "id": "me_encanta_bailar",
      "front": "I love dancing.",
      "back": "Me encanta bailar.",
      "grammarNote": "Encantar works like gustar but stronger. 'Me encanta' = I love it."
    },
    {
      "id": "te_gustan_peliculas",
      "front": "Do you like movies?",
      "back": "¿Te gustan las películas?"
    },
    {
      "id": "no_me_gusta_tristeza",
