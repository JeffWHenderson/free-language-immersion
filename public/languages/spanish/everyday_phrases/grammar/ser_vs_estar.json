{
  "id": "ser_vs_estar",
  "name": "Ser vs. Estar",
  "language": "spanish",
  "cards": [
    {
      "id": "soy",
      "front": "I am (permanent identity)",
      "back": "soy",
      "grammarNote": "Use ser for identity, origin, and permanent traits: nationality, profession, personality."
    },
    {
      "id": "estoy",
      "front": "I am (state or location)",
      "back": "estoy",
      "grammarNote": "Use estar for feelings, location, and temporary states."
    },
    {
      "id": "soy_de",
      "front": "I am from...",
      "back": "Soy de..."
    },
    {
      "id": "soy_americano",
      "front": "I am American.",
      "back": "Soy americano."
    },
    {
      "id": "estoy_bien",
      "front": "I'm doing well.",
      "back": "Estoy bien."
    },
    {
      "id": "estoy_aqui",
      "front": "I'm here.",
      "back": "Estoy aquí."
    },
    {
      "id": "es_mi_amigo",
      "front": "He is my friend.",
      "back": "Es mi amigo.",
      "grammarNote": "Ser for relationships and identity."
    },
    {
      "id": "esta_cansado",
      "front": "He is tired.",
      "back": "Está cansado.",
      "grammarNote": "Estar for temporary states — tiredness, mood, health."
    },
    {
      "id": "como_estas",
      "front": "How are you?",
      "back": "¿Cómo estás?"
    },
    {
      "id": "muy_bien",
      "front": "Very well, and you?",
      "back": "Muy bien, ¿y tú?"
    },
    {
      "id": "donde_estas",
      "front": "Where are you?",
      "back": "¿Dónde estás?"
    },
    {
      "id": "es_tarde",
      "front": "It's late.",
      "back": "Es tarde.",
      "grammarNote": "Use ser for time expressions: es tarde, es la una, son las dos."
    },
    {
      "id": "es_importante",
      "front": "It's important.",
      "back": "Es importante.",
      "grammarNote": "Use ser for inherent qualities and general truths."
    }
  ]
}
