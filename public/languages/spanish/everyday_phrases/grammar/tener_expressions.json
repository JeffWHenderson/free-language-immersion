{
  "id": "tener_expressions",
  "name": "Tener Expressions",
  "language": "spanish",
  "cards": [
    {
      "id": "tengo",
      "front": "I have",
      "back": "tengo",
      "grammarNote": "Tener (to have) is irregular in the yo form: tengo. Also used for age and physical/emotional states."
    },
    {
      "id": "tienes",
      "front": "you have",
      "back": "tienes"
    },
    {
      "id": "tengo_hambre",
      "front": "I'm hungry.",
      "back": "Tengo hambre.",
      "grammarNote": "Tener + noun expresses physical states. Literally 'I have hunger.' Never use estar for these."
    },
    {
      "id": "tengo_sed",
      "front": "I'm thirsty.",
      "back": "Tengo sed."
    },
    {
      "id": "tengo_sueno",
      "front": "I'm sleepy.",
      "back": "Tengo sueño."
    },
    {
      "id": "tengo_prisa",
      "front": "I'm in a hurry.",
      "back": "Tengo prisa."
    },
    {
      "id": "tengo_razon",
      "front": "I'm right.",
      "back": "Tengo razón.",
      "grammarNote": "Literally 'I have reason.' Common in corrections and arguments."
    },
    {
      "id": "tienes_razon",
      "front": "You're right.",
      "back": "Tienes razón."
    },
    {
      "id": "tengo_que",
      "front": "I have to...",
      "back": "Tengo que...",
      "grammarNote": "Tener + que + infinitive = obligation. 'Tengo que ir' = I have to go."
    },
    {
      "id": "tengo_que_ir",
      "front": "I have to go.",
      "back": "Tengo que ir."
    },
    {
      "id": "tengo_anos",
      "front": "I am 25 years old.",
      "back": "Tengo veinticinco años.",
      "grammarNote": "Age uses tener, not ser or estar. Literally 'I have 25 years.'"
    },
    {
      "id": "cuantos_anos",
      "front": "How old are you?",
      "back": "¿Cuántos años tienes?"
    }
  ]
}
