{
  "id": "tener_que",
  "name": "Tener que — Obligation & Necessity",
  "language": "spanish",
  "cards": [
    {
      "id": "tener_que_meaning",
      "front": "What does 'tener que + infinitive' mean?",
      "back": "have to / must",
      "grammarNote": "Pattern: subject + tener (conjugated) + que + infinitive. The infinitive never changes."
    },
    {
      "id": "tengo",
      "front": "I have to (tener que)",
      "back": "tengo que"
    },
    {
      "id": "tienes",
      "front": "you have to (tener que)",
      "back": "tienes que"
    },
    {
      "id": "tiene",
      "front": "he / she has to (tener que)",
      "back": "tiene que"
    },
    {
      "id": "tenemos",
      "front": "we have to (tener que)",
      "back": "tenemos que"
    },
    {
      "id": "tienen",
      "front": "they have to (tener que)",
      "back": "tienen que"
    },
    {
      "id": "i_have_to_work",
      "front": "I have to work.",
      "back": "Tengo que trabajar."
    },
    {
      "id": "you_have_to_study",
      "front": "You have to study.",
      "back": "Tienes que estudiar."
    },
    {
      "id": "she_has_to_go",
      "front": "She has to go to the doctor.",
      "back": "Ella tiene que ir al médico."
    },
    {
      "id": "necesitar",
      "front": "I need to rest. (use necesitar)",
      "back": "Necesito descansar.",
      "grammarNote": "Necesitar + infinitive = need to. Practical need, slightly softer than tener que."
    },
    {
      "id": "deber",
      "front": "I should eat more. (use deber)",
      "back": "Debo comer más.",
      "grammarNote": "Deber + infinitive = should / ought to. Used for moral duty or advice."
    },
    {
      "id": "do_you_have_to_work",
      "front": "Do you have to work tomorrow?",
      "back": "¿Tienes que trabajar mañana?"
    }
  ]
}
