{
  "id": "gustar",
  "name": "Gustar — I Like",
  "language": "spanish",
  "cards": [
    {
      "id": "me_gusta",
      "levels": [
        {
          "front": "I like (one thing)",
          "back": "me gusta",
          "grammarNote": "Literally: it pleases me. The thing you like is the subject."
        }
      ]
    },
    {
      "id": "me_gustan",
      "levels": [
        {
          "front": "I like (multiple)",
          "back": "me gustan",
          "grammarNote": "Gustan is plural because the subject (the things) is plural."
        }
      ]
    },
    {
      "id": "te_gusta",
      "levels": [
        {
          "front": "you like (one thing)",
          "back": "te gusta"
        }
      ]
    },
