          "back": "te gustan"
        }
      ]
    },
    {
      "id": "le_gusta",
      "levels": [
        {
          "front": "he / she likes",
          "back": "le gusta"
        }
      ]
    },
    {
      "id": "nos_gusta",
      "levels": [
        {
          "front": "we like",
          "back": "nos gusta"
        }
      ]
    },
