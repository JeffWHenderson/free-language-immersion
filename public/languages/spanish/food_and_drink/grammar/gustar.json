{
  "id": "gustar",
  "name": "Gustar — I Like",
  "language": "spanish",
  "cards": [
    {
      "id": "me_gusta",
      "front": "I like (one thing)",
      "back": "me gusta",
      "grammarNote": "Literally: it pleases me. The thing you like is the subject."
    },
    {
      "id": "me_gustan",
      "front": "I like (multiple)",
      "back": "me gustan",
      "grammarNote": "Gustan is plural because the subject (the things) is plural."
    },
    {
      "id": "te_gusta",
      "front": "you like (one thing)",
      "back": "te gusta"
    },
    {
      "id": "te_gustan",
      "front": "you like (multiple)",
      "back": "te gustan"
    },
    {
      "id": "le_gusta",
      "front": "he",
      "back": "le gusta"
    },
    {
      "id": "nos_gusta",
      "front": "we like",
      "back": "nos gusta"
    },
    {
      "id": "i_like_coffee",
      "front": "I like coffee.",
      "back": "Me gusta el café."
    },
    {
      "id": "i_like_tacos",
      "front": "I like tacos.",
      "back": "Me gustan los tacos.",
      "grammarNote": "Gustan because tacos is plural."
    },
    {
      "id": "like_spicy",
      "front": "Do you like spicy food?",
      "back": "¿Te gusta la comida picante?"
    },
    {
      "id": "no_fish",
      "front": "I don't like fish.",
      "back": "No me gusta el pescado."
    },
    {
      "id": "she_likes_water",
      "front": "She likes to drink water.",
      "back": "Le gusta beber agua.",
      "grammarNote": "Gustar + infinitive works too — the infinitive is singular."
    },
    {
      "id": "we_like_desserts",
      "front": "We like desserts.",
      "back": "Nos gustan los postres."
    },
    {
      "id": "what_you_like",
      "front": "What do you like to eat?",
      "back": "¿Qué te gusta comer?"
    },
    {
      "id": "cook_home",
      "front": "I like to cook at home.",
      "back": "Me gusta cocinar en casa."
    },
    {
      "id": "love_choc",
      "front": "I love chocolate.",
      "back": "Me encanta el chocolate.",
      "grammarNote": "Encantar = to love / really like. Same structure as gustar."
    },
    {
      "id": "no_meat",
      "front": "He doesn't like meat.",
      "back": "No le gusta la carne."
    },
    {
      "id": "like_wine",
      "front": "Do you like wine?",
      "back": "¿Te gusta el vino?"
    }
  ]
}
