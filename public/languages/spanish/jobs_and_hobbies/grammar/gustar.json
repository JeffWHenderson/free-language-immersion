{
  "id": "gustar",
  "name": "Gustar — I Like",
  "language": "spanish",
  "cards": [
    {
      "id": "me_gusta",
      "front": "I like (singular)",
      "back": "me gusta",
      "grammarNote": "Gustar works backwards — the thing you like is the subject. 'Me gusta el trabajo' = literally 'the job pleases me.'"
    },
    {
      "id": "me_gustan",
      "front": "I like (plural)",
      "back": "me gustan",
      "grammarNote": "Use gustan when the liked thing is plural: 'Me gustan los deportes.'"
    },
    {
      "id": "te_gusta",
      "front": "you like (singular)",
      "back": "te gusta"
    },
    {
      "id": "le_gusta",
      "front": "he/she likes",
      "back": "le gusta"
    },
    {
      "id": "me_gusta_trabajar",
      "front": "I like working.",
      "back": "Me gusta trabajar."
    },
    {
      "id": "me_gustan_deportes",
      "front": "I like sports.",
      "back": "Me gustan los deportes."
    },
    {
      "id": "te_gusta_cocinar",
      "front": "Do you like cooking?",
      "back": "¿Te gusta cocinar?"
    },
    {
      "id": "me_gusta_leer",
      "front": "I like reading.",
      "back": "Me gusta leer."
    },
    {
      "id": "no_me_gusta",
      "front": "I don't like working on weekends.",
      "back": "No me gusta trabajar los fines de semana."
    },
    {
      "id": "que_te_gusta",
      "front": "What do you like to do?",
      "back": "¿Qué te gusta hacer?"
    },
    {
      "id": "me_encanta",
      "front": "I love (it)",
      "back": "me encanta",
      "grammarNote": "Encantar works like gustar but is stronger — 'I love it / it enchants me.'"
    },
    {
      "id": "me_encanta_musica",
      "front": "I love music.",
      "back": "Me encanta la música."
    },
    {
      "id": "le_gusta_dibujar",
      "front": "She likes drawing.",
      "back": "Le gusta dibujar."
    }
  ]
}
