        {
          "front": "Give me the menu, please.",
          "back": "Dame el menú, por favor.",
          "literal": "Give-me the menu, please."
        }
      ]
    },
    {
      "id": "to_see",
      "hidden": true,
      "levels": [
        {
          "front": "To see",
          "back": "ver",
          "grammarNote": "ver is irregular in yo: veo. 'A ver' (let's see) is one of the most common filler expressions in Spanish."
        },
        {
          "front": "I can't see anything.",
          "back": "No puedo ver nada.",
          "literal": "[I] not can see nothing."
        }
      ]
    },
    {
      "id": "with",
      "levels": [
        {
          "front": "With",
          "back": "con"
        },
        {
          "front": "I came with my friend.",
          "back": "Vine con mi amigo.",
          "literal": "[I] came with my friend."
        }
      ]
    },
    {
      "id": "without",
      "levels": [
        {
          "front": "Without",
          "back": "sin"
        },
        {
