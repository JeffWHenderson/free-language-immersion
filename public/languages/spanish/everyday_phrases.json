    {
      "id": "why",
      "hidden": true,
      "levels": [
        {
          "front": "Why",
          "back": "por qué",
          "grammarNote": "por qué (two words, accents) = why? / porque (one word, no accent) = because. ¿Por qué no vienes? — Porque estoy cansado."
        },
        {
          "front": "Why can't you come?",
          "back": "¿Por qué no puedes venir?",
          "literal": "Why not can [you] come?"
        }
      ]
    },
    {
      "id": "how",
      "levels": [
        {
          "front": "How",
          "back": "cómo"
        },
        {
          "front": "How are you?",
          "back": "¿Cómo estás?",
          "literal": "How are [you]?"
        }
      ]
    },
    {
      "id": "good_morning",
      "levels": [
        {
          "front": "Good morning",
          "back": "buenos días",
          "grammarNote": "Spanish greetings by time: buenos días (morning), buenas tardes (afternoon/evening), buenas noches (night). Casually, just buenas works at any hour."
        },
        {
          "front": "Good morning! How did you sleep?",
          "back": "¡Buenos días! ¿Cómo dormiste?",
          "literal": "Good days! How slept [you]?"
        }
      ]
    },
    {
      "id": "to_look_for",
      "hidden": true,
      "levels": [
        {
          "front": "To look for",
          "back": "buscar"
        },
        {
          "front": "I'm looking for the exit.",
          "back": "Busco la salida.",
          "literal": "[I] search the exit."
        }
      ]
    },
    {
      "id": "excuse_me",
      "levels": [
        {
          "front": "Excuse me",
          "back": "perdón / con permiso",
          "grammarNote": "perdón = excuse me (apology or getting attention). con permiso = excuse me (when passing someone or leaving). disculpe is also common for getting a stranger's attention."
        },
        {
          "front": "Excuse me, where is the main street?",
          "back": "Perdón, ¿dónde está la calle principal?",
          "literal": "Excuse-me, where is the street main?"
        }
      ]
    },
    {
      "id": "to_be_able_to_can",
      "levels": [
        {
          "front": "To be able to / can",
          "back": "poder",
          "grammarNote": "poder stem-changes o→ue: yo puedo, tú puedes, él puede."
        },
        {
          "front": "Can you help me?",
          "back": "¿Puedes ayudarme?",
          "literal": "Can [you] help-me?"
        }
      ]
    },
    {
      "id": "i_dont_know",
      "levels": [
        {
          "front": "I don't know",
          "back": "no sé"
        },
        {
          "front": "I don't know where it is.",
          "back": "No sé dónde está.",
          "literal": "[I] not know where [it] is."
        }
      ]
    },
    {
      "id": "to_have",
      "levels": [
        {
          "front": "To have",
          "back": "tener",
          "grammarNote": "tener is irregular in yo: tengo. Also used for physical states: tener hambre (to be hungry), tener sed (to be thirsty), tener frío/calor (to be cold/hot)."
        },
        {
          "front": "I'm hungry. Do you have water?",
          "back": "Tengo hambre. ¿Tienes agua?",
          "literal": "[I] have hunger. Have [you] water?"
        }
      ]
    },
    {
      "id": "to_do_make",
      "levels": [
        {
          "front": "To do / make",
          "back": "hacer",
          "grammarNote": "hacer is irregular in yo: hago. Used in weather: 'Hace calor' (It's hot), 'Hace frío' (It's cold)."
        },
        {
          "front": "What are you doing?",
          "back": "¿Qué haces?",
          "literal": "What do [you]?"
        }
      ]
    },
    {
      "id": "to_eat",
      "levels": [
        {
          "front": "To eat",
          "back": "comer"
        },
        {
          "front": "Where are we eating?",
          "back": "¿Dónde comemos?",
          "literal": "Where eat [we]?"
        }
      ]
    },
    {
      "id": "to_like",
      "levels": [
        {
          "front": "To like",
          "back": "gustar",
          "grammarNote": "gustar works in reverse: the thing liked is the grammatical subject. 'Me gusta el café' = coffee pleases me = I like coffee. Singular: me gusta. Plural: me gustan ('Me gustan los libros')."
        },
        {
          "front": "I like coffee.",
          "back": "Me gusta el café.",
          "literal": "To-me pleases the coffee."
        }
      ]
    },
    {
      "id": "but",
      "levels": [
        {
          "front": "But",
          "back": "pero"
