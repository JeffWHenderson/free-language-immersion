      ]
    },
    {
      "id": "from_of",
      "levels": [
        {
          "front": "From / of",
          "back": "de",
          "grammarNote": "de is one of the most common Spanish words. de + el = del (contraction required): 'el libro del maestro' (the teacher's book). Used for origin, possession, and material."
        },
        {
          "front": "I'm from Mexico.",
          "back": "Soy de México.",
          "literal": "[I] am from Mexico."
        }
      ]
    },
    {
      "id": "good",
      "levels": [
        {
          "front": "Good",
          "back": "bueno / buena",
          "grammarNote": "bueno shortens to buen before masculine nouns: 'un buen día' (a good day). 'Buenas' alone is a casual greeting at any time of day."
        },
        {
          "front": "That's a good idea.",
          "back": "Es una buena idea.",
          "literal": "[It] is a good idea."
        }
      ]
    },
    {
      "id": "bad",
      "levels": [
        {
