    {
      "id": "food",
      "levels": [
        {
          "front": "Food",
          "back": "comida",
          "grammarNote": "Use estar (not ser) with food adjectives: 'La comida está deliciosa' (the food is [right now] delicious). ser would imply a permanent quality, which sounds odd for food."
        },
        {
          "front": "The food is delicious.",
          "back": "La comida está deliciosa."
        }
      ]
    },
