    {
      "id": "never",
      "hidden": true,
      "levels": [
        {
          "front": "Never",
          "back": "nunca",
          "grammarNote": "nunca usually comes before the verb. If placed after, add no before the verb: 'no llego tarde nunca'. Unlike English, double negatives are grammatically correct in Spanish."
        },
        {
          "front": "I never arrive late.",
          "back": "Nunca llego tarde.",
          "literal": "[I] never arrive late."
        }
      ]
    },
    {
      "id": "to_go",
      "levels": [
        {
          "front": "To go",
          "back": "ir",
          "grammarNote": "ir a + infinitive = going to do something: 'voy a comer' (I'm going to eat). Also: a + el contracts to al — 'voy al mercado' (not 'a el mercado')."
        },
        {
          "front": "I'm going to the store.",
          "back": "Voy a la tienda.",
          "literal": "[I] go to the store."
        }
      ]
    },
    {
      "id": "to_come",
      "levels": [
        {
          "front": "To come",
          "back": "venir",
          "grammarNote": "venir is irregular: yo vengo, tú vienes, él viene. 'Venir de' = to come from: '¿De dónde vienes?' (Where are you from?)."
        },
        {
          "front": "Where are you coming from?",
          "back": "¿De dónde vienes?",
          "literal": "From where come [you]?"
        }
      ]
    },
    {
      "id": "to_understand",
      "levels": [
        {
          "front": "To understand",
          "back": "entender",
          "grammarNote": "entender stem-changes e→ie: entiendo, entiendes, entiende."
        },
        {
          "front": "I don't understand.",
          "back": "No entiendo.",
          "literal": "[I] not understand."
        }
      ]
    },
    {
      "id": "to_speak_talk",
      "levels": [
        {
          "front": "To speak / talk",
          "back": "hablar",
          "grammarNote": "hablar is the model regular -ar verb: hablo, hablas, habla, hablamos, hablan. Most -ar verbs follow this pattern exactly."
        },
        {
          "front": "Do you speak Spanish?",
          "back": "¿Hablas español?",
          "literal": "Speak [you] Spanish?"
        }
      ]
    },
    {
      "id": "to_give",
      "hidden": true,
      "levels": [
        {
          "front": "To give",
          "back": "dar",
          "grammarNote": "dar is irregular in yo: doy. The command 'dame' (give me) is extremely common: 'Dame el menú' (Give me the menu)."
