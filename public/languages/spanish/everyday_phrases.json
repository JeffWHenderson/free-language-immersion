    {
      "id": "water",
      "levels": [
        {
          "front": "Water",
          "back": "agua",
          "grammarNote": "agua is feminine but uses 'el' in singular because it begins with a stressed 'a'. Adjectives still agree feminine: 'el agua fría'. Plural: las aguas."
        },
        {
          "front": "A glass of water, please.",
          "back": "Un vaso de agua, por favor."
        }
      ]
