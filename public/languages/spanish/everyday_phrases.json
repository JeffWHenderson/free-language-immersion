    {
      "id": "i_want",
      "levels": [
        {
          "front": "I want",
          "back": "quiero",
          "grammarNote": "querer stem-changes e→ie: yo quiero, tú quieres, él quiere."
        },
        {
          "front": "I want a coffee.",
          "back": "Quiero un café.",
          "literal": "[I] want a coffee."
        }
      ]
    },
    {
      "id": "i_need",
      "levels": [
        {
          "front": "I need",
          "back": "necesito"
        },
        {
          "front": "I need help.",
          "back": "Necesito ayuda.",
          "literal": "[I] need help."
        }
      ]
    },
    {
      "id": "my_name_is",
      "levels": [
        {
          "front": "My name is",
          "back": "me llamo",
          "grammarNote": "Me llamo literally means 'I call myself' — it uses the reflexive verb llamarse. More natural in conversation than 'mi nombre es'."
        },
        {
          "front": "My name is Ana.",
          "back": "Me llamo Ana.",
          "literal": "[I] myself-call Ana."
        }
      ]
    },
    {
      "id": "i",
      "levels": [
        {
          "front": "I",
          "back": "yo",
          "grammarNote": "Subject pronouns are often dropped in Spanish because verb endings show who the subject is. 'Soy estudiante' and 'Yo soy estudiante' are both correct — use yo for emphasis."
        },
        {
          "front": "I am a student.",
          "back": "Yo soy estudiante.",
          "literal": "I am student."
        }
      ]
    },
    {
      "id": "you",
      "levels": [
        {
          "front": "You",
          "back": "tú",
          "grammarNote": "Spanish has two 'you': tú (informal, one person) and usted (formal). With friends use tú. With strangers, elders, or in formal settings use usted, which takes the same verb form as él/ella."
        },
        {
          "front": "Do you speak Spanish?",
          "back": "¿Tú hablas español?",
          "literal": "You speak Spanish?"
        }
      ]
    },
    {
      "id": "he",
      "hidden": true,
      "levels": [
        {
          "front": "He",
          "back": "él"
        },
        {
          "front": "He is my friend.",
          "back": "Él es mi amigo."
        }
      ]
    },
    {
      "id": "she",
      "hidden": true,
      "levels": [
        {
          "front": "She",
          "back": "ella"
        },
        {
          "front": "She works here.",
          "back": "Ella trabaja aquí."
        }
      ]
    },
    {
      "id": "it",
      "hidden": true,
      "levels": [
        {
          "front": "It",
          "back": "ello / lo",
          "grammarNote": "Spanish usually drops 'it' entirely — verb endings and context carry the meaning. 'Es bueno' (it is good), 'Está aquí' (it is here). ello/lo exist but are rarely used in speech."
        },
        {
          "front": "It's over there.",
          "back": "Está allá.",
          "literal": "[It] is there."
        }
      ]
    },
    {
      "id": "we",
