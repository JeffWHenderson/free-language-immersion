      ]
    },
    {
      "id": "for",
      "levels": [
        {
          "front": "For",
          "back": "para / por",
          "grammarNote": "para = purpose or destination: 'un regalo para ti' (a gift for you). por = cause, exchange, duration: 'gracias por tu ayuda' (thanks for your help), 'por dos horas' (for two hours)."
        },
        {
