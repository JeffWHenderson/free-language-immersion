{
  "id": "bu_negation",
  "name": "不 & 没 — Negation",
  "language": "chinese",
  "cards": [
    {
      "id": "bu",
      "front": "not (verbs & adjectives)",
      "back": "不",
      "romanized": "bù",
      "grammarNote": "不 negates verbs and adjectives. Tone changes to bú before a 4th-tone syllable."
    },
    {
      "id": "mei",
      "front": "not (for 有 & completed actions)",
      "back": "没",
      "romanized": "méi",
      "grammarNote": "Use 没/没有 to negate 有 or to say something did not happen."
    },
    {
      "id": "not_going",
      "front": "I am not going.",
      "back": "我不去。",
      "romanized": "Wǒ bú qù."
    },
    {
      "id": "dont_like",
      "front": "I don't like it.",
      "back": "我不喜欢。",
      "romanized": "Wǒ bù xǐhuān."
    },
    {
      "id": "not_happy",
      "front": "I am not happy.",
      "back": "我不高兴。",
      "romanized": "Wǒ bù gāoxìng."
    },
    {
      "id": "no_money",
      "front": "I don't have money.",
      "back": "我没有钱。",
      "romanized": "Wǒ méiyǒu qián.",
      "grammarNote": "Always use 没有 to negate 有."
    },
    {
      "id": "didnt_eat",
      "front": "He didn't eat.",
      "back": "他没吃。",
      "romanized": "Tā méi chī.",
      "grammarNote": "没 negates a past action — something that didn't happen."
    },
    {
      "id": "dont_understand",
      "front": "I don't understand.",
      "back": "我不明白。",
      "romanized": "Wǒ bù míngbai."
    },
    {
      "id": "not_good",
      "front": "This is not good.",
      "back": "这不好。",
      "romanized": "Zhè bù hǎo."
    },
    {
      "id": "never_been",
      "front": "I haven't been there.",
      "back": "我没去过。",
      "romanized": "Wǒ méi qùguò.",
      "grammarNote": "过 marks experience; 没 negates it."
    },
    {
      "id": "no_english",
      "front": "She doesn't speak English.",
      "back": "她不说英语。",
      "romanized": "Tā bù shuō yīngyǔ."
    },
    {
      "id": "didnt_see",
      "front": "I didn't see it.",
      "back": "我没看见。",
      "romanized": "Wǒ méi kànjiàn."
    },
    {
      "id": "not_bad",
      "front": "Not bad!",
      "back": "不错！",
      "romanized": "Bú cuò!",
      "grammarNote": "不错 literally 'not wrong' — means pretty good."
    },
    {
      "id": "dont_go",
      "front": "Don't go!",
      "back": "不要走！",
      "romanized": "Bú yào zǒu!"
    },
    {
      "id": "not_tired",
      "front": "I'm not tired.",
      "back": "我不累。",
      "romanized": "Wǒ bú lèi."
    },
    {
      "id": "bu_vs_mei",
      "front": "I didn't go. (past)",
      "back": "我没去。",
      "romanized": "Wǒ méi qù.",
      "grammarNote": "没 = didn't (past). 不 = won't / don't (present/future intention)."
    }
  ]
}
