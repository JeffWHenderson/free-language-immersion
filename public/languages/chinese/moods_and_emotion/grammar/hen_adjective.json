{
  "id": "hen_adjective",
  "name": "很 + Adjective",
  "language": "chinese",
  "cards": [
    {
      "id": "hen",
      "front": "very",
      "back": "很",
      "romanized": "hěn",
      "grammarNote": "很 is required before adjectives in positive statements — even when you don't mean 'very.' Without it, the sentence implies a comparison."
    },
    {
      "id": "im_happy",
      "front": "I am happy.",
      "back": "我很高兴。",
      "romanized": "Wǒ hěn gāoxìng."
    },
    {
      "id": "im_tired",
      "front": "I am tired.",
      "back": "我很累。",
      "romanized": "Wǒ hěn lèi."
    },
    {
      "id": "hes_busy",
      "front": "He is busy.",
      "back": "他很忙。",
      "romanized": "Tā hěn máng."
    },
    {
      "id": "shes_pretty",
      "front": "She is beautiful.",
      "back": "她很漂亮。",
      "romanized": "Tā hěn piàoliang."
    },
    {
      "id": "food_good",
      "front": "The food is delicious.",
      "back": "食物很好吃。",
      "romanized": "Shíwù hěn hǎo chī."
    },
    {
      "id": "expensive",
      "front": "It's expensive.",
      "back": "很贵。",
      "romanized": "Hěn guì."
    },
    {
      "id": "not_expensive",
      "front": "It's not expensive.",
      "back": "不贵。",
      "romanized": "Bú guì.",
      "grammarNote": "In negative sentences, 不 replaces 很. Don't say 不很贵."
    },
    {
      "id": "very_happy",
      "front": "I am very happy today.",
      "back": "我今天非常高兴。",
      "romanized": "Wǒ jīntiān fēicháng gāoxìng.",
      "grammarNote": "非常 (fēicháng) = extremely. Stronger than 很."
    },
    {
      "id": "are_you_busy",
      "front": "Are you busy?",
      "back": "你忙吗？",
      "romanized": "Nǐ máng ma?",
      "grammarNote": "No 很 in questions — just adjective + 吗."
    },
    {
      "id": "interesting",
      "front": "This is interesting.",
      "back": "这很有趣。",
