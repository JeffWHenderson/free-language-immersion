      "id": "not_tired",
      "front": "I am not tired.",
      "back": "我不累。",
      "romanized": "Wǒ bú lèi."
    },
    {
      "id": "good_movie",
      "front": "The movie is good.",
      "back": "电影很好看。",
      "romanized": "Diànyǐng hěn hǎokàn."
    },
    {
      "id": "nice_weather",
      "front": "The weather is great.",
      "back": "天气很好。",
      "romanized": "Tiānqì hěn hǎo."
    },
    {
      "id": "a_little",
      "front": "I'm a little nervous.",
      "back": "我有点紧张。",
      "romanized": "Wǒ yǒudiǎn jǐnzhāng.",
