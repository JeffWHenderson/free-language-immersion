{
  "id": "zhengzai_progressive",
  "name": "正在 — Progressive Aspect",
  "language": "chinese",
  "cards": [
    {
      "id": "zz_working",
      "front": "I am working right now.",
      "back": "我正在工作。",
      "romanized": "Wǒ zhèngzài gōngzuò.",
      "grammarNote": "正在 + verb = currently doing (right now). 正 adds emphasis on the 'right now' aspect. 正在 can also appear as just 在 for a lighter form."
    },
    {
      "id": "zz_working_ne",
      "front": "I'm working right now. (with 呢 for emphasis)",
      "back": "我正在工作呢。",
      "romanized": "Wǒ zhèngzài gōngzuò ne."
    },
    {
      "id": "zz_in_meeting",
      "front": "He is in a meeting.",
      "back": "他在开会。",
      "romanized": "Tā zài kāihuì.",
      "grammarNote": "在 alone (without 正) is also a valid progressive marker. 在 + verb = currently doing. Slightly less emphatic than 正在."
    },
    {
      "id": "zz_sleeping_ne",
      "front": "He's sleeping. (implied: don't disturb)",
      "back": "他睡觉呢。",
      "romanized": "Tā shuìjiào ne.",
      "grammarNote": "呢 alone at the end of a sentence can signal an ongoing action, often implying the situation is still going on or asking the listener not to interrupt."
    },
    {
      "id": "zz_studying",
      "front": "She's studying right now.",
      "back": "她正在学习呢。",
      "romanized": "Tā zhèngzài xuéxí ne."
    },
    {
      "id": "zz_practicing",
      "front": "They are practicing singing.",
      "back": "他们在练习唱歌。",
      "romanized": "Tāmen zài liànxí chànggē."
    },
    {
      "id": "zz_writing",
      "front": "I'm writing right now.",
      "back": "我正在写作。",
      "romanized": "Wǒ zhèngzài xiězuò."
    },
    {
      "id": "zz_painting",
      "front": "She's painting.",
      "back": "她在画画呢。",
      "romanized": "Tā zài huàhuà ne."
    },
    {
      "id": "zz_neg_working",
      "front": "He's not working right now.",
      "back": "他没有在工作。",
      "romanized": "Tā méiyǒu zài gōngzuò.",
      "grammarNote": "Negation: 没有在 or 没在 before the verb. Never use 不在 for this meaning — 不在 means 'not at a place.'"
    },
    {
      "id": "zz_neg_sleeping",
      "front": "I'm not sleeping.",
      "back": "我没在睡觉。",
      "romanized": "Wǒ méi zài shuìjiào."
    },
    {
      "id": "zz_neg_meeting",
      "front": "They aren't in a meeting.",
      "back": "他们没有在开会。",
      "romanized": "Tāmen méiyǒu zài kāihuì."
    },
    {
      "id": "zz_exercising",
      "front": "She is exercising right now.",
      "back": "她正在运动。",
      "romanized": "Tā zhèngzài yùndòng."
    }
  ]
}
