{
  "id": "hui_neng",
  "name": "会、能、可以 — Can",
  "language": "chinese",
  "cards": [
    {
      "id": "hui",
      "front": "can (learned skill)",
      "back": "会",
      "romanized": "huì",
      "grammarNote": "会 = a skill you have learned, like speaking a language or driving."
    },
    {
      "id": "neng",
      "front": "can (circumstantial)",
      "back": "能",
      "romanized": "néng",
      "grammarNote": "能 = physically able to, or circumstances allow it."
    },
    {
      "id": "keyi",
      "front": "can",
      "back": "可以",
      "romanized": "kěyǐ",
      "grammarNote": "可以 = it is allowed / permissible."
    },
    {
      "id": "speak_chinese",
      "front": "I can speak Chinese.",
      "back": "我会说中文。",
      "romanized": "Wǒ huì shuō zhōngwén."
    },
    {
      "id": "can_drive",
      "front": "Can you drive?",
      "back": "你会开车吗？",
      "romanized": "Nǐ huì kāi chē ma?"
    },
    {
      "id": "cant_come",
      "front": "I can't come today.",
      "back": "我今天不能来。",
      "romanized": "Wǒ jīntiān bù néng lái.",
      "grammarNote": "能 is used because circumstances (schedule) prevent it."
    },
    {
      "id": "sit_here",
      "front": "Can I sit here?",
      "back": "我可以坐这里吗？",
      "romanized": "Wǒ kěyǐ zuò zhèlǐ ma?",
      "grammarNote": "可以 = asking for permission."
    },
    {
      "id": "can_cook",
      "front": "He can cook.",
      "back": "他会做饭。",
      "romanized": "Tā huì zuò fàn."
    },
    {
      "id": "cant_swim",
      "front": "I can't swim.",
      "back": "我不会游泳。",
      "romanized": "Wǒ bú huì yóuyǒng."
    },
    {
      "id": "you_can_go",
      "front": "You can go now.",
      "back": "你可以走了。",
      "romanized": "Nǐ kěyǐ zǒu le."
    },
    {
      "id": "can_we_start",
      "front": "Can we start?",
      "back": "我们可以开始吗？",
      "romanized": "Wǒmen kěyǐ kāishǐ ma?"
    },
    {
      "id": "can_help",
      "front": "I am able to help.",
      "back": "我能帮忙。",
      "romanized": "Wǒ néng bāngmáng."
    },
    {
      "id": "three_langs",
      "front": "She can speak three languages.",
      "back": "她会说三种语言。",
      "romanized": "Tā huì shuō sān zhǒng yǔyán."
    },
    {
      "id": "too_busy",
      "front": "I can't go — I'm busy.",
      "back": "我不能去，我很忙。",
      "romanized": "Wǒ bù néng qù, wǒ hěn máng."
    },
    {
      "id": "ask_question",
      "front": "Can I ask a question?",
      "back": "我可以问一个问题吗？",
      "romanized": "Wǒ kěyǐ wèn yí gè wèntí ma?"
    },
    {
      "id": "cant_today",
      "front": "I can't today.",
      "back": "我今天不行。",
      "romanized": "Wǒ jīntiān bù xíng.",
      "grammarNote": "不行 (bù xíng) = won't work / can't — a common informal way to say no."
    }
  ]
}
