{
  "id": "yao_xiang",
  "name": "要 & 想 — Want / Would Like",
  "language": "chinese",
  "cards": [
    {
      "id": "yao",
      "front": "want to / will (strong intention)",
      "back": "要",
      "romanized": "yào",
      "grammarNote": "要 (yào) expresses a firm desire or plan. Stronger than 想 — closer to 'I'm going to' or 'I need to'."
    },
    {
      "id": "xiang",
      "front": "would like to / thinking of",
      "back": "想",
      "romanized": "xiǎng",
      "grammarNote": "想 (xiǎng) is softer than 要 — a wish or intention without being definite."
    },
    {
