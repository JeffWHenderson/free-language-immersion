        {
          "front": "Please",
          "back": "请",
          "romanized": "qǐng",
          "grammarNote": "请 (qǐng) precedes a verb to make a polite request: 请坐 (please sit), 请问 (may I ask). For offering something: 请 alone. To ask for an item: 给我... 好吗? or just 来一个... (bring one...)."
        },
        {
          "front": "A coffee, please.",
          "back": "请给我一杯咖啡。",
          "romanized": "Qǐng gěi wǒ yī bēi kāfēi.",
          "literal": "Please give me one cup coffee."
        }
      ]
    },
