{
  "id": "hui_neng",
  "name": "会、能、可以 — Can",
  "language": "chinese",
  "cards": [
    {
      "id": "hui",
      "front": "can (learned skill)",
      "back": "会",
      "romanized": "huì",
      "grammarNote": "会 (huì) = can because you learned how. Used for skills: speaking, swimming, driving."
    },
    {
      "id": "neng",
      "front": "can (physically able)",
      "back": "能",
      "romanized": "néng",
      "grammarNote": "能 (néng) = physically able to, or permitted by circumstances. Used when a condition makes it possible."
    },
    {
      "id": "keyi",
      "front": "may / can (permission)",
      "back": "可以",
      "romanized": "kěyǐ",
      "grammarNote": "可以 (kěyǐ) = permitted to / allowed to. Used to seek or grant permission."
    },
    {
      "id": "wo_neng_zou",
      "front": "Can I walk (am I able to)?",
      "back": "我能走了吗？",
      "romanized": "Wǒ néng zǒu le ma?"
    },
    {
      "id": "keyi_xiuxi",
      "front": "Can I rest?",
      "back": "我可以休息吗？",
      "romanized": "Wǒ kěyǐ xiūxi ma?"
    },
    {
      "id": "wo_bu_neng_dong",
      "front": "I can't move.",
      "back": "我不能动。",
      "romanized": "Wǒ bù néng dòng."
    },
    {
      "id": "ni_keyi_xiuxi",
      "front": "You can rest now.",
      "back": "你可以休息了。",
      "romanized": "Nǐ kěyǐ xiūxi le."
    },
    {
      "id": "bu_neng_chi",
      "front": "I can't eat this.",
      "back": "我不能吃这个。",
      "romanized": "Wǒ bù néng chī zhège."
    },
    {
      "id": "keyi_he_shui",
      "front": "Can I drink water?",
      "back": "我可以喝水吗？",
      "romanized": "Wǒ kěyǐ hē shuǐ ma?"
    },
    {
      "id": "man_man_zou",
      "front": "Walk slowly.",
      "back": "慢慢走。",
      "romanized": "Màn màn zǒu."
    },
    {
      "id": "neng_hao_ma",
      "front": "Will you get better?",
      "back": "能好吗？",
      "romanized": "Néng hǎo ma?"
    }
  ]
}
