{
  "id": "direction_complements",
  "name": "Direction Complements — 上来, 出去, 回来",
  "language": "chinese",
  "cards": [
    {
      "id": "dc_jinlai",
      "front": "Please come in!",
      "back": "请进来！",
      "romanized": "Qǐng jìn lái!",
      "grammarNote": "Direction complements = direction word (进/出/上/下/回/过) + 来 or 去. 来 = toward the speaker. 去 = away from the speaker. 进来 = come in (moving inward toward speaker)."
    },
    {
      "id": "dc_chuqu",
      "front": "He went out.",
      "back": "他出去了。",
      "romanized": "Tā chū qù le."
    },
    {
      "id": "dc_huilai",
      "front": "When are you coming back?",
      "back": "你什么时候回来？",
      "romanized": "Nǐ shénme shíhou huí lái?"
    },
    {
      "id": "dc_guolai",
      "front": "Come over here quickly!",
      "back": "快过来！",
      "romanized": "Kuài guò lái!"
    },
    {
      "id": "dc_shanglai",
      "front": "come up (toward speaker)",
      "back": "上来",
      "romanized": "shàng lái"
    },
    {
      "id": "dc_shangqu",
      "front": "go up (away from speaker)",
      "back": "上去",
      "romanized": "shàng qù",
      "grammarNote": "Same direction word, different 来/去 based on whether movement is toward or away from the speaker. Context makes it clear which to use."
    },
    {
      "id": "dc_xialai",
      "front": "come down (toward speaker)",
      "back": "下来",
      "romanized": "xià lái"
    },
    {
      "id": "dc_xiaqu",
      "front": "go down (away from speaker)",
      "back": "下去",
      "romanized": "xià qù"
    },
    {
      "id": "dc_climb_up",
      "front": "He climbed up (away from me).",
      "back": "他爬上去了。",
      "romanized": "Tā pá shàng qù le."
    },
    {
      "id": "dc_food_served",
      "front": "The food has been brought up / is being served.",
      "back": "菜端上来了。",
      "romanized": "Cài duān shàng lái le."
    },
    {
      "id": "dc_huiqu",
      "front": "go back (return away from speaker)",
      "back": "回去",
      "romanized": "huí qù"
    },
    {
      "id": "dc_ran_out",
      "front": "She ran out of the hotel.",
      "back": "她从酒店跑出去了。",
      "romanized": "Tā cóng jiǔdiàn pǎo chū qù le."
    }
  ]
}
