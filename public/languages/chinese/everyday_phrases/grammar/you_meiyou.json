{
  "id": "you_meiyou",
  "name": "有 & 没有 — Have / Don't Have",
  "language": "chinese",
  "cards": [
    {
      "id": "you",
      "front": "to have / there is",
      "back": "有",
      "romanized": "yǒu",
      "grammarNote": "有 (yǒu) means both 'to have' and 'there is/are'. Context makes it clear which."
    },
    {
      "id": "meiyou",
      "front": "to not have / there is no",
      "back": "没有",
      "romanized": "méiyǒu",
      "grammarNote": "没有 negates 有. Never use 不有 — only 没有 is correct."
    },
    {
      "id": "wo_you",
      "front": "I have...",
      "back": "我有...",
      "romanized": "Wǒ yǒu..."
    },
    {
      "id": "ni_you_ma",
      "front": "Do you have...?",
      "back": "你有...吗？",
      "romanized": "Nǐ yǒu...ma?"
    },
    {
      "id": "wo_meiyou",
      "front": "I don't have...",
      "back": "我没有...",
      "romanized": "Wǒ méiyǒu..."
    },
    {
      "id": "you_shijian",
      "front": "Do you have time?",
      "back": "你有时间吗？",
      "romanized": "Nǐ yǒu shíjiān ma?"
    },
    {
      "id": "wo_meiyou_shijian",
      "front": "I don't have time.",
      "back": "我没有时间。",
      "romanized": "Wǒ méiyǒu shíjiān."
    },
    {
      "id": "you_wenti",
      "front": "Is there a problem?",
      "back": "有问题吗？",
      "romanized": "Yǒu wèntí ma?"
    },
    {
      "id": "meiyou_wenti",
      "front": "No problem.",
      "back": "没有问题。",
      "romanized": "Méiyǒu wèntí."
    },
    {
      "id": "ni_you_pengyou",
      "front": "Do you have friends here?",
      "back": "你在这里有朋友吗？",
      "romanized": "Nǐ zài zhèlǐ yǒu péngyou ma?"
    },
    {
      "id": "wo_you_yige",
      "front": "I have one.",
      "back": "我有一个。",
      "romanized": "Wǒ yǒu yī gè."
    },
    {
      "id": "you_mei_you",
      "front": "Do you have it or not? (informal)",
      "back": "有没有？",
      "romanized": "Yǒu méiyǒu?",
