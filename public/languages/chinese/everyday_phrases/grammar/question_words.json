{
  "id": "question_words",
  "name": "Question Words — 什么, 谁, 哪里...",
  "language": "chinese",
  "cards": [
    {
      "id": "qw_what_eating",
      "front": "What are you eating?",
      "back": "你吃什么？",
      "romanized": "Nǐ chī shénme?",
      "grammarNote": "Question words stay in the position of the unknown information — they don't move to the front. 你吃什么 has the same word order as 你吃饭 (you eat rice)."
    },
    {
      "id": "qw_who_is_that",
      "front": "Who is that person?",
      "back": "那个人是谁？",
      "romanized": "Nàge rén shì shéi?"
    },
    {
      "id": "qw_where_live",
      "front": "Where do you live?",
      "back": "你住在哪里？",
      "romanized": "Nǐ zhù zài nǎlǐ?"
    },
    {
      "id": "qw_when_coming",
      "front": "When are you coming?",
      "back": "你什么时候来？",
      "romanized": "Nǐ shénme shíhou lái?"
    },
    {
      "id": "qw_how_get_there",
      "front": "How are you getting there?",
      "back": "你怎么去？",
      "romanized": "Nǐ zěnme qù?"
    },
    {
      "id": "qw_why_not_going",
      "front": "Why aren't you going?",
      "back": "你为什么不去？",
      "romanized": "Nǐ wèishénme bù qù?"
    },
    {
      "id": "qw_how_much",
      "front": "How much does this cost?",
      "back": "这个多少钱？",
      "romanized": "Zhège duōshao qián?",
      "grammarNote": "多少 (duōshao) asks about quantities. 多少钱 literally means 'how much money.' No measure word is needed between 多少 and 钱."
    },
    {
      "id": "qw_which_one",
      "front": "Which one do you want?",
      "back": "你要哪个？",
      "romanized": "Nǐ yào nǎge?"
    },
    {
      "id": "qw_what_is_this",
      "front": "What is this?",
      "back": "这是什么？",
      "romanized": "Zhè shì shénme?"
    },
    {
      "id": "qw_where_bathroom",
      "front": "Where is the bathroom?",
      "back": "洗手间在哪里？",
      "romanized": "Xǐshǒujiān zài nǎlǐ?"
    },
    {
      "id": "qw_who_is_she",
      "front": "Who is she?",
      "back": "她是谁？",
      "romanized": "Tā shì shéi?"
    },
    {
      "id": "qw_why_late",
      "front": "Why are you late?",
      "back": "你为什么迟到了？",
      "romanized": "Nǐ wèishénme chídào le?"
    }
  ]
